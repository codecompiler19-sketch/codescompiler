---
export interface Props {
  initialHtml?: string;
  initialCss?: string;
  initialJs?: string;
  initialPhp?: string;
  activeTab?: string;
  height?: string;
}

const {
  initialHtml = `<h1>Hello, CodesCompiler!</h1>\n<p>Edit this code and click <b>Run ▶</b></p>`,
  initialCss  = `body {\n  font-family: sans-serif;\n  padding: 2rem;\n  background: #f0f4f8;\n}\nh1 { color: #04AA6D; }\np  { color: #555; }`,
  initialJs   = `// Your JavaScript here\nconsole.log("Welcome to CodesCompiler!");`,
  initialPhp  = ``,
  activeTab   = `html`,
  height = '520px',
} = Astro.props;

// Each Editor instance gets a unique ID so multiple editors on one page work independently
const uid = Math.random().toString(36).slice(2, 9);
---

<div
  class="not-prose tiy-root my-8 rounded-xl border border-gray-200 shadow-lg overflow-hidden bg-[#1e1e2e]"
  style={`height:${height}`}
  data-html={initialHtml}
  data-css={initialCss}
  data-js={initialJs}
  data-php={initialPhp}
  data-active={activeTab}
  data-uid={uid}
>
  <!-- ── Header ──────────────────────────────────────────── -->
  <div class="flex items-center justify-between px-4 py-2 bg-[#181825] border-b border-white/10">
    <div class="flex items-center gap-1.5">
      <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-400/80"></span>
      <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
      <span class="ml-3 text-xs text-gray-400 font-mono hidden sm:block">try-it-yourself — CodesCompiler</span>
    </div>

    <!-- Tab buttons -->
    <div class="flex rounded-md overflow-hidden border border-white/10" role="tablist">
      <button role="tab" aria-selected={activeTab === 'html' ? 'true' : 'false'} class={`tiy-tab px-4 py-1.5 text-xs font-bold font-mono ${activeTab === 'html' ? 'active-tab' : ''}`} data-lang="html">HTML</button>
      <button role="tab" aria-selected={activeTab === 'css' ? 'true' : 'false'} class={`tiy-tab px-4 py-1.5 text-xs font-bold font-mono ${activeTab === 'css' ? 'active-tab' : ''}`} data-lang="css">CSS</button>
      <button role="tab" aria-selected={activeTab === 'js' ? 'true' : 'false'} class={`tiy-tab px-4 py-1.5 text-xs font-bold font-mono ${activeTab === 'js' ? 'active-tab' : ''}`} data-lang="js">JS</button>
      {initialPhp !== '' && <button role="tab" aria-selected={activeTab === 'php' ? 'true' : 'false'} class={`tiy-tab px-4 py-1.5 text-xs font-bold font-mono ${activeTab === 'php' ? 'active-tab' : ''}`} data-lang="php">PHP</button>}
    </div>

    <!-- Run button -->
    <button class="tiy-run flex items-center gap-1.5 px-4 py-1.5 bg-[#04AA6D] hover:bg-[#038a58] text-white text-xs font-bold rounded transition-colors">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
        <path d="M6.3 2.84A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.27l9.344-5.891a1.5 1.5 0 000-2.538L6.3 2.84z"/>
      </svg>
      Run
    </button>
  </div>

  <!-- ── Body ───────────────────────────────────────────── -->
  <div class="flex h-[calc(100%-2.5rem)]">

    <!-- Editor pane -->
    <div class="w-1/2 border-r border-white/10 flex flex-col overflow-hidden">
      <div class="tiy-editor flex-1 overflow-auto text-sm"></div>
    </div>

    <!-- Preview pane -->
    <div class="w-1/2 flex flex-col bg-white">
      <div class="flex items-center justify-between px-3 py-1.5 bg-gray-50 border-b border-gray-200">
        <span class="text-xs text-gray-400 font-mono">Preview</span>
        <div class="flex gap-1">
          <span class="w-2 h-2 rounded-full bg-gray-300"></span>
          <span class="w-2 h-2 rounded-full bg-gray-300"></span>
          <span class="w-2 h-2 rounded-full bg-gray-300"></span>
        </div>
      </div>
      <iframe class="tiy-preview flex-1 w-full border-none" title="Live Preview" sandbox="allow-scripts"></iframe>
    </div>

  </div>
</div>

<!-- Single initialiser — runs once, finds every .tiy-root on the page -->
<script is:inline type="module">
  // Guard: only run the initialiser once per page load
  if (!window.__tiyInit) {
    window.__tiyInit = true;

    const BASE = 'https://esm.sh';

    async function initAll() {
      // Load CodeMirror modules once, shared across all editor instances
      const [
        { EditorState },
        { EditorView, keymap, lineNumbers, highlightActiveLineGutter, highlightActiveLine, drawSelection },
        { defaultKeymap, history, historyKeymap, indentWithTab },
        { html:   htmlLang  },
        { css:    cssLang   },
        { javascript: jsLang },
        { php:    phpLang   },
        { oneDark },
        { autocompletion, completionKeymap },
        { bracketMatching },
        { closeBrackets, closeBracketsKeymap },
      ] = await Promise.all([
        import(`${BASE}/@codemirror/state`),
        import(`${BASE}/@codemirror/view`),
        import(`${BASE}/@codemirror/commands`),
        import(`${BASE}/@codemirror/lang-html`),
        import(`${BASE}/@codemirror/lang-css`),
        import(`${BASE}/@codemirror/lang-javascript`),
        import(`${BASE}/@codemirror/lang-php`),
        import(`${BASE}/@codemirror/theme-one-dark`),
        import(`${BASE}/@codemirror/autocomplete`),
        import(`${BASE}/@codemirror/language`),
        import(`${BASE}/@codemirror/autocomplete`),
      ]);

      const baseExtensions = [
        lineNumbers(),
        highlightActiveLineGutter(),
        highlightActiveLine(),
        drawSelection(),
        history(),
        bracketMatching(),
        closeBrackets(),
        autocompletion(),
        oneDark,
        keymap.of([
          ...defaultKeymap,
          ...historyKeymap,
          ...completionKeymap,
          ...closeBracketsKeymap,
          indentWithTab,
        ]),
        EditorView.lineWrapping,
      ];

      const langExt = { html: htmlLang(), css: cssLang(), js: jsLang(), php: phpLang() };

      // Init each editor on the page independently
      document.querySelectorAll('.tiy-root').forEach(wrapper => {
        const editorEl = wrapper.querySelector('.tiy-editor');
        const preview  = wrapper.querySelector('.tiy-preview');
        const runBtn   = wrapper.querySelector('.tiy-run');
        const tabs     = wrapper.querySelectorAll('.tiy-tab');

        // Read initial code from data attributes
        const unescapeText = (txt) => {
          if (!txt) return '';
          return txt.replace(/\\n/g, '\n');
        };

        const docs = {
          html: unescapeText(wrapper.dataset.html),
          css:  unescapeText(wrapper.dataset.css),
          js:   unescapeText(wrapper.dataset.js),
          php:  unescapeText(wrapper.dataset.php),
        };

        let currentLang = wrapper.dataset.active || 'html';
        let view = null;

        function createEditor(lang) {
          if (view) {
            docs[currentLang] = view.state.doc.toString();
            view.destroy();
          }
          currentLang = lang;
          view = new EditorView({
            state: EditorState.create({
              doc: docs[lang],
              extensions: [...baseExtensions, langExt[lang]],
            }),
            parent: editorEl,
          });
        }

        function runPreview() {
          if (view) docs[currentLang] = view.state.doc.toString();
          
          let fullDoc = '';

          // Determine the runtime environment
          if (wrapper.dataset.php !== '') {
            // PHP WASM Environment — pass code via JSON.stringify to avoid HTML-escaping issues
            let phpCode = docs.php;
            if (!phpCode.trimStart().startsWith('<?php') && !phpCode.trimStart().startsWith('<?')) {
              phpCode = '<?php\n' + phpCode;
            }
            const jsonCode = JSON.stringify(phpCode);
            fullDoc = `<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <style>body { font-family: sans-serif; padding: 1.5rem; background: #fff; }</style>
</head>
<body>
<div id="output"><span style="color:#aaa;font-family:monospace;">Executing PHP...</span></div>
<script type="module">
  import { PhpWeb } from 'https://cdn.jsdelivr.net/npm/php-wasm/PhpWeb.mjs';
  const php = new PhpWeb();
  const outputDiv = document.getElementById('output');
  const code = ${jsonCode};

  php.addEventListener('output', (event) => {
    outputDiv.innerHTML += event.detail;
  });

  php.addEventListener('error', (event) => {
    outputDiv.innerHTML += '<br><span style="color:red">' + event.detail + '</span>';
  });

  php.addEventListener('ready', () => {
    outputDiv.innerHTML = '';
    php.run(code).catch(err => {
      outputDiv.innerHTML += '<br><span style="color:red">Error: ' + err + '</span>';
    });
  });
<\/script>
</body>
</html>`;
          } else {
            // Standard Web Environment (HTML/CSS/JS)
            // IMPORTANT: JS runs at top-level so function declarations are globally accessible.
            // If wrapped in try{}, block-scoped function declarations break onclick handlers.
            const safeJs = docs.js.replace(/<\/script>/gi, '<\\/script>');
            fullDoc = `<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <style>${docs.css}</style>
</head>
<body>
${docs.html}
<script>
${safeJs}
<\/script>
</body>
</html>`;
          }

          // PHP-WASM needs Web Workers → requires allow-same-origin.
          // HTML/CSS/JS keeps allow-scripts only for security.
          if (wrapper.dataset.php !== '') {
            preview.setAttribute('sandbox', 'allow-scripts allow-same-origin');
          } else {
            preview.setAttribute('sandbox', 'allow-scripts');
          }

          const blob = new Blob([fullDoc], { type: 'text/html' });
          const blobUrl = URL.createObjectURL(blob);
          preview.src = blobUrl;
        }

        // Tab switching
        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            tabs.forEach(t => {
              t.classList.remove('active-tab');
              t.setAttribute('aria-selected', 'false');
            });
            tab.classList.add('active-tab');
            tab.setAttribute('aria-selected', 'true');
            createEditor(tab.dataset.lang);
          });
        });

        runBtn?.addEventListener('click', runPreview);

        // Boot: init editor to default active tab and auto-run preview
        createEditor(currentLang);
        runPreview();
      });
    }

    initAll().catch(console.error);
  }
</script>

<style is:global>
  .tiy-tab {
    background: transparent;
    color: #9ca3af;
    border: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .tiy-tab:hover     { background: rgba(255,255,255,0.08); color: #e5e7eb; }
  .tiy-tab.active-tab { background: #04AA6D; color: #fff; }

  .tiy-root .cm-editor {
    height: 100%;
    font-size: 13px;
    font-family: 'Fira Code', 'JetBrains Mono', 'Cascadia Code', monospace;
  }
  .tiy-root .cm-scroller { overflow: auto; }

  .cm-editor.cm-focused { outline: none; }
  .cm-editor .cm-gutters {
    background: #1a1b26 !important;
    border-right: 1px solid rgba(255,255,255,0.06) !important;
  }
  .cm-editor .cm-activeLineGutter { background: rgba(255,255,255,0.05); }

  @media (max-width: 640px) {
    .tiy-root .flex.h-\[calc\(100\%-2\.5rem\)\] { flex-direction: column; }
    .tiy-root .w-1\/2 { width: 100%; height: 50%; }
  }
</style>

