---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  currentSlug: string;
  topicIcon: string;
}

const { title, description, currentSlug, topicIcon } = Astro.props;

// All kids topics — sidebar list
const kidsTopics = [
  { slug: 'what-is-a-computer',   icon: '💻', label: 'What is a Computer?',       tag: 'Beginner'    },
  { slug: 'what-is-a-cpu',        icon: '🧠', label: 'What is a CPU?',             tag: 'Hardware'    },
  { slug: 'memory-and-storage',   icon: '💾', label: 'Memory & Storage',           tag: 'Hardware'    },
  { slug: 'how-internet-works',   icon: '🌐', label: 'How the Internet Works',     tag: 'Internet'    },
  { slug: 'what-is-a-website',    icon: '🌍', label: 'What is a Website?',         tag: 'Internet'    },
  { slug: 'online-safety',        icon: '🔐', label: 'Online Safety for Kids',     tag: 'Safety'      },
  { slug: 'what-is-ai',           icon: '🤖', label: 'What is AI?',                tag: 'Technology'  },
  { slug: 'what-is-coding',       icon: '👩‍💻', label: 'What is Coding?',           tag: 'Coding'      },
  { slug: 'how-games-are-made',   icon: '🎮', label: 'How Are Games Made?',        tag: 'Fun'         },
];

const currentIdx = kidsTopics.findIndex(t => t.slug === currentSlug);
const prev = currentIdx > 0 ? kidsTopics[currentIdx - 1] : null;
const next = currentIdx < kidsTopics.length - 1 ? kidsTopics[currentIdx + 1] : null;
---

<BaseLayout title={title} description={description}>
  <!-- TUTORIAL SUB-HEADER FOR MOBILE SIDEBAR -->
  <div slot="sub-header" class="md:hidden bg-[#1b1b2f] text-white flex items-center px-4 py-2 w-full relative z-10 shadow-md">
    <button id="sidebar-toggle" class="p-1 mr-3 rounded hover:bg-white/10 transition-colors" aria-label="Toggle sidebar">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
    <span class="font-semibold text-sm tracking-wide truncate flex-1 text-center pr-10">{title}</span>
  </div>

  <div class="flex-1 flex overflow-hidden">

    <!-- ============================================================ -->
    <!-- LEFT SIDEBAR — Kids Topics List                               -->
    <!-- ============================================================ -->
    <aside
      id="page-sidebar"
      class="fixed top-[150px] bottom-0 left-0 z-50 md:z-0 w-64 bg-white border-r border-gray-100 transform -translate-x-full transition-transform duration-200 ease-in-out md:relative md:top-0 md:translate-x-0 overflow-y-auto"
    >
      <!-- Category badge -->
      <div class="px-3 py-3 border-b border-gray-200 bg-gray-50 sticky top-0">
        <span class="inline-block text-xs font-bold uppercase tracking-widest px-2 py-1 rounded bg-green-100 text-green-700">
          Kids Tutorial
        </span>
      </div>

      <!-- Topic links -->
      <nav class="py-2 flex flex-col" aria-label="Kids topics">
        {kidsTopics.map((topic) => {
          const isActive = topic.slug === currentSlug;
          return (
            <a
              href={`/kids/${topic.slug}`}
              aria-current={isActive ? 'page' : undefined}
              class={`block px-4 py-2 text-[0.82rem] font-medium border-l-4 transition-colors flex items-center gap-2 ${
                isActive
                  ? 'border-[#04AA6D] bg-[#04AA6D] text-white'
                  : 'border-transparent text-gray-600 hover:bg-gray-50 hover:text-[#04AA6D]'
              }`}
            >
              <span class="text-base">{topic.icon}</span>
              <span>{topic.label}</span>
            </a>
          );
        })}
      </nav>

      <!-- Back to Kids Home -->
      <div class="px-3 py-4 border-t border-gray-100">
        <a
          href="/kids"
          class="flex items-center gap-2 text-xs font-semibold text-gray-400 hover:text-[#04AA6D] transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to Kids Home
        </a>
      </div>
    </aside>

    <!-- Overlay backdrop (mobile) -->
    <div
      id="sidebar-backdrop"
      class="fixed top-[150px] bottom-0 left-0 right-0 bg-black/50 z-30 hidden md:hidden"
    ></div>

    <!-- ============================================================ -->
    <!-- MAIN ARTICLE AREA                                             -->
    <!-- ============================================================ -->
    <div class="flex flex-1 min-w-0">
      <article class="flex-1 min-w-0 px-5 sm:px-8 lg:px-14 py-8 bg-white">

        <!-- Breadcrumb -->
        <nav class="text-xs text-gray-400 mb-6 flex items-center gap-1 flex-wrap" aria-label="Breadcrumb">
          <a href="/" class="hover:text-[#04AA6D] transition-colors">Home</a>
          <span>/</span>
          <a href="/kids" class="hover:text-[#04AA6D] transition-colors">Kids</a>
          <span>/</span>
          <span class="text-gray-600 truncate max-w-[180px]">{title}</span>
        </nav>

        <!-- Page Title -->
        <div class="mb-6 pb-5 border-b border-gray-100">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-4xl">{topicIcon}</span>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{title}</h1>
          </div>
          <p class="text-base text-gray-500">{description}</p>
        </div>

        <!-- Kids-friendly info banner -->
        <div class="mb-6 flex items-center gap-3 bg-green-50 border border-green-200 rounded-lg px-4 py-3 text-sm font-semibold text-green-700">
          <span class="text-xl">👶</span>
          Written in simple, fun language — perfect for kids ages 8 and up!
        </div>

        <!-- Content slot -->
        <div class="prose prose-gray prose-sm sm:prose-base max-w-none
          prose-headings:font-bold prose-headings:text-gray-900
          prose-a:text-[#04AA6D] prose-a:no-underline hover:prose-a:underline
          prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-[#c7254e] prose-code:text-sm prose-code:font-normal
          prose-pre:bg-[#282A35] prose-pre:text-gray-100 prose-pre:rounded-lg
          prose-blockquote:border-[#04AA6D] prose-blockquote:bg-green-50 prose-blockquote:py-1
          prose-li:text-gray-700">
          <slot />
        </div>

        <!-- Prev / Next navigation -->
        {(prev || next) && (
          <div class="mt-12 pt-8 border-t border-gray-100 flex items-center justify-between">
            {prev && (
              <a href={`/kids/${prev.slug}`} class="flex items-center gap-2 text-sm font-semibold text-gray-500 hover:text-[#04AA6D] transition-colors">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                {prev.icon} {prev.label}
              </a>
            )}
            {next && (
              <a href={`/kids/${next.slug}`} class="flex items-center gap-2 text-sm font-semibold text-[#04AA6D] hover:underline ml-auto">
                {next.icon} {next.label}
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            )}
          </div>
        )}
      </article>
    </div>
  </div>

  <!-- Mobile sidebar toggle script (same as TutorialLayout) -->
  <script is:inline>
    (function () {
      const btn      = document.getElementById('sidebar-toggle');
      const sidebar  = document.getElementById('page-sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');
      if (!btn || !sidebar || !backdrop) return;
      function openSidebar() {
        sidebar.classList.remove('-translate-x-full');
        sidebar.classList.add('translate-x-0');
        backdrop.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      function closeSidebar() {
        sidebar.classList.add('-translate-x-full');
        sidebar.classList.remove('translate-x-0');
        backdrop.classList.add('hidden');
        document.body.style.overflow = '';
      }
      btn.addEventListener('click', () => {
        const isOpen = !sidebar.classList.contains('-translate-x-full');
        if (isOpen) { closeSidebar(); } else { openSidebar(); }
      });
      backdrop.addEventListener('click', closeSidebar);
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768) {
          backdrop.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });
    })();
  </script>
</BaseLayout>
