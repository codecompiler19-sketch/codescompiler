---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  image?: string;
  date?: string;
  category?: string;
  tags?: string[];
  author?: string;
  slug?: string;
  hasDemo?: boolean;
}

const { title, description, image, date, category, tags = [], author = 'CodesCompiler', slug = '', hasDemo = false } = Astro.props;

// Fetch all posts for sidebar panels
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const recentPosts = sortedPosts.slice(0, 6);

// Category counts
const categoryCounts = allPosts.reduce((acc, post) => {
  const cat = post.data.category;
  acc[cat] = (acc[cat] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

// Format date
const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

// Category badge colors + slugs
const CATEGORY_MAP: Record<string, { color: string; bg: string; href: string }> = {
  'HTML & CSS':          { color: '#E34F26', bg: '#fff4f0', href: '/blog?cat=html-css' },
  'JavaScript':          { color: '#ca8a04', bg: '#fefce8', href: '/blog?cat=javascript' },
  'JavaScript Projects': { color: '#eab308', bg: '#fef9c3', href: '/blog?cat=javascript-projects' },
  'Login Form':          { color: '#3b82f6', bg: '#eff6ff', href: '/blog?cat=login-form' },
  'Card Design':         { color: '#8b5cf6', bg: '#f5f3ff', href: '/blog?cat=card-design' },
  'Navigation Bar':      { color: '#ec4899', bg: '#fdf2f8', href: '/blog?cat=navigation-bar' },
  'Blog':                { color: '#10b981', bg: '#ecfdf5', href: '/blog?cat=blog' },
  'Website Designs':     { color: '#06b6d4', bg: '#ecfeff', href: '/blog?cat=website-designs' },
  'Image Slider':        { color: '#f97316', bg: '#fff7ed', href: '/blog?cat=image-slider' },
  'API Projects':        { color: '#6366f1', bg: '#eef2ff', href: '/blog?cat=api-projects' },
  'Sidebar Menu':        { color: '#84cc16', bg: '#f7fee7', href: '/blog?cat=sidebar-menu' },
  'CSS Buttons':         { color: '#f43f5e', bg: '#fff1f2', href: '/blog?cat=css-buttons' },
  'JavaScript Games':    { color: '#a855f7', bg: '#faf5ff', href: '/blog?cat=javascript-games' },
  'Preloader or Loader': { color: '#0ea5e9', bg: '#f0f9ff', href: '/blog?cat=preloader-or-loader' },
  'Form Validation':     { color: '#14b8a6', bg: '#f0fdfa', href: '/blog?cat=form-validation' },
  'Accordion':           { color: '#e11d48', bg: '#ffe4e6', href: '/blog?cat=accordion' },
  'Bootstrap':           { color: '#7e22ce', bg: '#faf5ff', href: '/blog?cat=bootstrap' },
  'Tabs':                { color: '#0369a1', bg: '#e0f2fe', href: '/blog?cat=tabs' },
  'Calendar':            { color: '#b91c1c', bg: '#fef2f2', href: '/blog?cat=calendar' }
};
const catMeta = category ? (CATEGORY_MAP[category] ?? { color: '#6b7280', bg: '#f3f4f6', href: '/blog' }) : null;

// All unique tags across posts
const allTags = [...new Set(allPosts.flatMap(p => p.data.tags ?? []))].sort();
---

<BaseLayout title={title} description={description} image={image}>
  <!-- ======================================================== -->
  <!-- FULL-WIDTH BREADCRUMB BAR                                 -->
  <!-- ======================================================== -->
  <div class="post-breadcrumb-bar">
    <div class="post-container">
      <nav class="post-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">›</span>
        <a href="/blog">Posts</a>
        <span class="sep">›</span>
        <span class="current" title={title}>{title}</span>
      </nav>
    </div>
  </div>

  <!-- ======================================================== -->
  <!-- THREE-COLUMN BODY: [LEFT SIDEBAR] [ARTICLE] [RIGHT AD]   -->
  <!-- ======================================================== -->
  <div class="post-container post-body">

    <!-- Mobile sidebar toggle button -->
    <button class="mobile-sidebar-btn" id="postSidebarToggle" aria-label="Open sidebar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      Filters &amp; Categories
    </button>

    <!-- ── LEFT SIDEBAR ─────────────────────────────────────── -->
    <aside class="post-sidebar" id="postSidebar">

      <!-- Categories -->
      <div class="sidebar-widget">
        <h3 class="widget-title">📂 Categories</h3>
        <ul class="category-list">
          <li>
            <a href="/blog" class="cat-link cat-all">
              <span class="cat-icon">🌐</span>
              <span class="cat-name">All Posts</span>
              <span class="cat-count">{allPosts.length}</span>
            </a>
          </li>
          {Object.entries(CATEGORY_MAP).map(([name, meta]) => (
            <li>
              <a href={meta.href} class="cat-link" style={`--cat-color:${meta.color};--cat-bg:${meta.bg}`}>
                <span class="cat-dot" style={`background:${meta.color}`}></span>
                <span class="cat-name">{name}</span>
                <span class="cat-count">{categoryCounts[name] ?? 0}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Recent Posts -->
      <div class="sidebar-widget">
        <h3 class="widget-title">🕒 Recent Posts</h3>
        <ul class="recent-list">
          {recentPosts.map(post => (
            <li class="recent-item">
              <a href={`/blog/${post.slug}`} class="recent-link">
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="recent-thumb"
                    loading="lazy"
                    width="56"
                    height="56"
                  />
                )}
                <div class="recent-info">
                  <span class="recent-title">{post.data.title}</span>
                  <span class="recent-date">
                    {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Tags -->
      {allTags.length > 0 && (
        <div class="sidebar-widget">
          <h3 class="widget-title">🏷️ Tags</h3>
          <div class="tag-cloud">
            {allTags.map(tag => (
              <a href={`/blog?tag=${tag}`} class="tag-pill">#{tag}</a>
            ))}
          </div>
        </div>
      )}

      <!-- Follow / Share Widget -->
      <div class="sidebar-widget widget-share">
        <h3 class="widget-title">📢 Share This Post</h3>
        <div class="share-buttons">
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent('https://codescompiler.com')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn share-twitter"
          >𝕏 Twitter</a>
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent('https://codescompiler.com')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn share-facebook"
          >Facebook</a>
          <a
            href={`https://api.whatsapp.com/send?text=${encodeURIComponent(title + ' ' + 'https://codescompiler.com')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn share-whatsapp"
          >WhatsApp</a>
        </div>
      </div>
    </aside>

    <!-- ── MAIN ARTICLE ──────────────────────────────────────── -->
    <main class="post-main" id="postMain">

      <!-- Featured Image -->
      {image && (
        <div class="post-featured-img-wrap">
          <img
            src={image}
            alt={title}
            class="post-featured-img"
            width="900"
            height="475"
          />
        </div>
      )}

      <!-- Demo + Download Action Bar (shown when hasDemo=true) -->
      {hasDemo && slug && (
        <div class="post-demo-bar">
          <div class="demo-bar-left">
            <span class="demo-bar-icon">🚀</span>
            <span class="demo-bar-text">See it in action</span>
          </div>
          <div class="demo-bar-actions">
            <a
              href={`/blog-demo/${slug}`}
              target="_blank"
              rel="noopener noreferrer"
              class="demo-btn demo-btn-green"
              id="btn-live-demo"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Live Demo
            </a>
            <a
              href={`/demos/${slug}.html`}
              download={`${slug}.html`}
              class="demo-btn demo-btn-outline"
              id="btn-download"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              Download
            </a>
          </div>
        </div>
      )}

      <!-- Post Header -->
      <header class="post-header">
        {catMeta && category && (
          <a
            href={catMeta.href}
            class="post-cat-badge"
            style={`color:${catMeta.color};background:${catMeta.bg};border-color:${catMeta.color}30`}
          >
            {category}
          </a>
        )}
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>

        <!-- Meta row -->
        <div class="post-meta">
          <span class="meta-author">
            <span class="meta-avatar">CC</span>
            {author}
          </span>
          {formattedDate && (
            <span class="meta-date">📅 {formattedDate}</span>
          )}
          {tags.length > 0 && (
            <div class="meta-tags">
              {tags.map(t => <span class="meta-tag">#{t}</span>)}
            </div>
          )}
        </div>
      </header>

      <hr class="post-divider" />

      <!-- MDX – Post Content -->
      <div class="post-content">
        <slot />
      </div>

      <hr class="post-divider" />

      <!-- Back to Posts -->
      <div class="post-footer-nav">
        <a href="/blog" class="back-btn">← Back to All Posts</a>
      </div>
    </main>

    <!-- ── RIGHT SIDEBAR (Ads) ──────────────────────────────── -->
    <aside class="post-ad-col">
      <div class="ad-sticky">
        <AdSlot format="rectangle" />
        <div class="ad-spacer"></div>
        <AdSlot format="rectangle" />
      </div>
    </aside>

  </div><!-- /post-body -->
</BaseLayout>

<!-- ================================================================ -->
<!-- STYLES                                                            -->
<!-- ================================================================ -->
<style is:global>
  /* ── Base container ─────────────────────────────────────────────── */
  .post-container {
    width: 100%;
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Breadcrumb bar */
  .post-breadcrumb-bar {
    background: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
    padding: 10px 0;
  }
  .post-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    flex-wrap: wrap;
  }
  .post-breadcrumb a { color: #04AA6D; text-decoration: none; }
  .post-breadcrumb a:hover { text-decoration: underline; }
  .post-breadcrumb .sep { color: #9ca3af; }
  .post-breadcrumb .current { color: #6b7280; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* ── Three-column layout ────────────────────────────────────────── */
  .post-body {
    display: grid;
    grid-template-columns: 260px 1fr 300px;
    gap: 28px;
    align-items: start;
    padding-top: 24px;
    padding-bottom: 48px;
  }

  @media (max-width: 1200px) {
    .post-body { grid-template-columns: 240px 1fr; }
    .post-ad-col { display: none; }
  }
  @media (max-width: 768px) {
    .post-body { grid-template-columns: 1fr; }
    .post-sidebar { display: none; }
  }

  /* ── LEFT SIDEBAR ──────────────────────────────────────────────── */
  .post-sidebar {
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #e5e7eb transparent;
    padding-right: 4px;
  }
  .post-sidebar::-webkit-scrollbar { width: 4px; }
  .post-sidebar::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 4px; }

  .sidebar-widget {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 18px;
    margin-bottom: 18px;
  }
  .widget-title {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #374151;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 2px solid #f3f4f6;
  }

  /* Categories */
  .category-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
  .cat-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 8px;
    text-decoration: none;
    color: #374151;
    font-size: 13.5px;
    font-weight: 500;
    transition: background .15s;
  }
  .cat-link:hover { background: #f3f4f6; }
  .cat-link.cat-all:hover { background: #f0fdf4; color: #04AA6D; }
  .cat-icon { font-size: 15px; }
  .cat-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .cat-name { flex: 1; }
  .cat-count {
    font-size: 11px;
    font-weight: 700;
    background: #f3f4f6;
    color: #6b7280;
    padding: 2px 8px;
    border-radius: 20px;
    min-width: 24px;
    text-align: center;
  }

  /* Recent Posts */
  .recent-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .recent-item {}
  .recent-link {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    group: true;
  }
  .recent-thumb {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid #f3f4f6;
  }
  .recent-info { display: flex; flex-direction: column; gap: 4px; }
  .recent-title {
    font-size: 13px;
    font-weight: 600;
    color: #1f2937;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .15s;
  }
  .recent-link:hover .recent-title { color: #04AA6D; }
  .recent-date { font-size: 11px; color: #9ca3af; }

  /* Tag cloud */
  .tag-cloud { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag-pill {
    font-size: 12px;
    font-weight: 600;
    color: #04AA6D;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    padding: 4px 10px;
    border-radius: 20px;
    text-decoration: none;
    transition: background .15s, color .15s;
  }
  .tag-pill:hover { background: #04AA6D; color: #fff; border-color: #04AA6D; }

  /* Share */
  .share-buttons { display: flex; flex-direction: column; gap: 8px; }
  .share-btn {
    display: block;
    text-align: center;
    padding: 9px 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity .2s, transform .1s;
  }
  .share-btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .share-twitter  { background: #000; color: #fff; }
  .share-facebook { background: #1877f2; color: #fff; }
  .share-whatsapp { background: #25d366; color: #fff; }

  /* ── MAIN ARTICLE ──────────────────────────────────────────────── */
  .post-main {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    min-width: 0;
  }

  .post-featured-img-wrap {
    width: 100%;
    aspect-ratio: 16/8;
    overflow: hidden;
  }
  .post-featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-header { padding: 28px 32px 0; }
  .post-cat-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 14px;
    border-radius: 20px;
    border: 1px solid transparent;
    text-decoration: none;
    margin-bottom: 14px;
  }

  .post-title {
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 900;
    color: #111827;
    line-height: 1.25;
    margin-bottom: 10px;
  }
  .post-description {
    font-size: 16px;
    color: #6b7280;
    line-height: 1.7;
    margin-bottom: 18px;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
  }
  .meta-author {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 600;
    color: #374151;
  }
  .meta-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #04AA6D;
    color: #fff;
    font-size: 10px;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .meta-date { font-size: 13px; color: #9ca3af; }
  .meta-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .meta-tag {
    font-size: 11px;
    font-weight: 700;
    color: #6b7280;
    background: #f3f4f6;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .post-divider { border: none; border-top: 1px solid #f3f4f6; margin: 20px 0; }

  /* MDX content styles */
  .post-content {
    padding: 4px 32px 32px;
    font-size: 16px;
    line-height: 1.8;
    color: #374151;
  }
  .post-content h2 {
    font-size: 22px;
    font-weight: 800;
    margin: 32px 0 12px;
    color: #111827;
    border-left: 4px solid #04AA6D;
    padding-left: 12px;
  }
  .post-content h3 {
    font-size: 18px;
    font-weight: 700;
    margin: 24px 0 10px;
    color: #1f2937;
  }
  .post-content p { margin-bottom: 18px; }
  .post-content ul, .post-content ol { margin: 12px 0 18px 22px; }
  .post-content li { margin-bottom: 6px; }
  .post-content a { color: #04AA6D; text-decoration: underline; }
  .post-content a:hover { color: #038a58; }
  .post-content code {
    background: #f3f4f6;
    color: #c7254e;
    padding: 2px 7px;
    border-radius: 5px;
    font-size: 14px;
    font-family: 'Fira Code', monospace;
  }
  .post-content pre {
    background: #1e1e2e;
    color: #e4e4e7;
    padding: 20px 24px;
    border-radius: 12px;
    overflow-x: auto;
    margin: 20px 0;
    border: 1px solid rgba(255,255,255,0.05);
    position: relative;
  }
  .post-content pre code {
    background: transparent;
    color: inherit;
    padding: 0;
    font-size: 14px;
    line-height: 1.7;
  }
  .post-content blockquote {
    border-left: 4px solid #04AA6D;
    background: #f0fdf4;
    padding: 14px 20px;
    border-radius: 0 10px 10px 0;
    margin: 20px 0;
    color: #374151;
    font-style: italic;
  }
  .post-content blockquote strong { color: #04AA6D; font-style: normal; }
  .post-content img {
    max-width: 100%;
    border-radius: 12px;
    margin: 20px 0;
    border: 1px solid #e5e7eb;
  }
  .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 14px;
  }
  .post-content th {
    background: #f9fafb;
    font-weight: 700;
    color: #374151;
    padding: 10px 16px;
    text-align: left;
    border: 1px solid #e5e7eb;
  }
  .post-content td {
    padding: 9px 16px;
    border: 1px solid #e5e7eb;
    color: #374151;
  }
  .post-content tr:nth-child(even) td { background: #f9fafb; }
  .post-content hr { border: none; border-top: 1px solid #e5e7eb; margin: 24px 0; }

  .post-footer-nav { padding: 0 32px 32px; }
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 22px;
    background: #f3f4f6;
    color: #374151;
    font-weight: 700;
    font-size: 14px;
    border-radius: 8px;
    text-decoration: none;
    transition: background .15s;
  }
  .back-btn:hover { background: #e5e7eb; }

  /* ── RIGHT AD COLUMN ──────────────────────────────────────────── */
  .post-ad-col { min-width: 0; }
  .ad-sticky {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .ad-spacer { height: 0; }

  @media (max-width: 600px) {
    .post-header { padding: 20px 18px 0; }
    .post-content { padding: 4px 18px 24px; }
    .post-footer-nav { padding: 0 18px 24px; }
  }

  /* ── DEMO + DOWNLOAD ACTION BAR ────────────────────────────────── */
  .post-demo-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding: 14px 24px;
    background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
    border-bottom: 1px solid #d1fae5;
  }
  .demo-bar-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .demo-bar-icon { font-size: 20px; }
  .demo-bar-text {
    font-size: 14px;
    font-weight: 700;
    color: #065f46;
  }
  .demo-bar-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .demo-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 20px;
    border-radius: 9px;
    font-size: 13.5px;
    font-weight: 800;
    text-decoration: none;
    transition: all .2s;
    border: 2px solid transparent;
    white-space: nowrap;
    cursor: pointer;
  }
  .demo-btn-green {
    background: #04AA6D;
    color: #fff;
    box-shadow: 0 4px 14px rgba(4,170,109,0.3);
  }
  .demo-btn-green:hover {
    background: #038a58;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(4,170,109,0.4);
  }
  .demo-btn-outline {
    background: #fff;
    color: #374151;
    border-color: #d1d5db;
  }
  .demo-btn-outline:hover {
    border-color: #04AA6D;
    color: #04AA6D;
    transform: translateY(-2px);
  }

  /* ── MOBILE SIDEBAR HAMBURGER ──────────────────────────────────── */
  .mobile-sidebar-btn {
    display: none;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    font-size: 13.5px;
    font-weight: 700;
    color: #374151;
    cursor: pointer;
    font-family: inherit;
    transition: background .15s, border-color .15s;
    margin-bottom: 16px;
    /* spans the full column on mobile */
    grid-column: 1 / -1;
  }
  .mobile-sidebar-btn:hover { background: #f9fafb; border-color: #04AA6D; color: #04AA6D; }
  @media (max-width: 768px) {
    .mobile-sidebar-btn { display: flex; }
  }

  /* Mobile sidebar — becomes full-screen overlay slide-in */
  @media (max-width: 768px) {
    .post-sidebar {
      display: block !important;   /* override the display:none */
      position: fixed;
      top: 0;
      left: 0;
      width: min(300px, 85vw);
      height: 100dvh;
      background: #fff;
      z-index: 200;
      padding: 20px 16px;
      box-shadow: 4px 0 32px rgba(0,0,0,0.18);
      transform: translateX(-110%);
      transition: transform .28s cubic-bezier(0.4, 0, 0.2, 1);
      max-height: none;
      overflow-y: auto;
    }
    .post-sidebar.sidebar-open {
      transform: translateX(0);
    }
    /* Close button inside sidebar */
    .sidebar-close-btn {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      margin-bottom: 12px;
    }
    .sidebar-close-btn button {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 7px 14px;
      background: #f3f4f6;
      border: none;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 700;
      color: #374151;
      cursor: pointer;
      font-family: inherit;
    }
  }
  @media (min-width: 769px) {
    .sidebar-close-btn { display: none; }
  }

  /* Overlay backdrop for mobile sidebar */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 199;
    backdrop-filter: blur(2px);
  }
  .sidebar-overlay.show { display: block; }
</style>

<!-- ============================================================ -->
<!-- MOBILE SIDEBAR JS                                            -->
<!-- ============================================================ -->
<script is:inline>
  (function () {
    const toggleBtn = document.getElementById('postSidebarToggle');
    const sidebar   = document.getElementById('postSidebar');
    if (!toggleBtn || !sidebar) return;

    // Inject close button at top of sidebar (only mobile)
    const closeRow = document.createElement('div');
    closeRow.className = 'sidebar-close-btn';
    closeRow.innerHTML = '<button id="sidebarCloseBtn">✕ Close</button>';
    sidebar.prepend(closeRow);

    // Inject overlay
    const overlay = document.createElement('div');
    overlay.className = 'sidebar-overlay';
    overlay.id = 'sidebarOverlay';
    document.body.appendChild(overlay);

    function openSidebar() {
      sidebar.classList.add('sidebar-open');
      overlay.classList.add('show');
      document.body.style.overflow = 'hidden';
    }
    function closeSidebar() {
      sidebar.classList.remove('sidebar-open');
      overlay.classList.remove('show');
      document.body.style.overflow = '';
    }

    toggleBtn.addEventListener('click', openSidebar);
    document.getElementById('sidebarCloseBtn').addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 769) closeSidebar();
    });
  })();
</script>

