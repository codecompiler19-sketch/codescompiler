      /* ============================================================ */
      /* STICKY SOCIAL MEDIA SIDEBAR CSS                             */
      /* ============================================================ */
      .social-sidebar {
        position: fixed;
        left: 0;
        top: 55%;
        transform: translateY(-50%);
        z-index: 1000;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(229, 231, 235, 0.6);
        border-left: none;
        border-radius: 0 16px 16px 0;
        padding: 12px 8px;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.08), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.3s, border-color 0.3s;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .social-sidebar.collapsed {
        transform: translate(-100%, -50%);
      }

      .social-sidebar-toggle {
        position: absolute;
        right: -12px;
        top: 50%;
        transform: translateY(-50%);
        width: 24px;
        height: 24px;
        background: #04AA6D;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        color: #ffffff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(4, 170, 109, 0.35);
        transition: background-color 0.2s, transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0;
      }

      .social-sidebar-toggle:hover {
        background: #038a58;
      }

      .social-sidebar.collapsed .social-sidebar-toggle {
        transform: translateY(-50%) rotate(180deg);
      }

      .social-sidebar-toggle .toggle-icon {
        transition: transform 0.3s;
      }

      .social-items {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .social-item {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        color: #4b5563;
        background: rgba(243, 244, 246, 0.8);
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        text-decoration: none;
      }

      /* Hover States with Brand Custom Settings */
      .social-item.youtube:hover {
        background: #FF0000;
        color: #ffffff;
        box-shadow: 0 5px 15px rgba(255, 0, 0, 0.4);
      }
      .social-item.instagram:hover {
        background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
        color: #ffffff;
        box-shadow: 0 5px 15px rgba(220, 39, 67, 0.4);
      }
      .social-item.facebook:hover {
        background: #1877F2;
        color: #ffffff;
        box-shadow: 0 5px 15px rgba(24, 119, 242, 0.4);
      }
      .social-item.threads:hover {
        background: #101010;
        color: #ffffff;
        box-shadow: 0 5px 15px rgba(16, 16, 16, 0.4);
      }
      .social-item.linkedin:hover {
        background: #0A66C2;
        color: #ffffff;
        box-shadow: 0 5px 15px rgba(10, 102, 194, 0.4);
      }
      .social-item.pinterest:hover {
        background: #BD081C;
        color: #ffffff;
        box-shadow: 0 5px 15px rgba(189, 8, 28, 0.4);
      }

      /* Tooltip Styles */
      .social-tooltip {
        position: absolute;
        left: 50px;
        top: 50%;
        transform: translateY(-50%) translateX(-8px);
        background: #1b1b2f;
        color: #ffffff;
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        opacity: 0;
        pointer-events: none;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        white-space: nowrap;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
      }

      .social-tooltip::before {
        content: '';
        position: absolute;
        right: 100%;
        top: 50%;
        transform: translateY(-50%);
        border-width: 5px;
        border-style: solid;
        border-color: transparent #1b1b2f transparent transparent;
      }

      .social-item:hover .social-tooltip {
        opacity: 1;
        transform: translateY(-50%) translateX(0);
      }

      /* Dark Mode overrides */
      html.dark-theme .social-sidebar {
        background: rgba(15, 23, 42, 0.85) !important;
        border-color: rgba(51, 65, 85, 0.6) !important;
      }
      html.dark-theme .social-item {
        color: #94a3b8;
        background: rgba(30, 41, 59, 0.8);
      }
      html.dark-theme .social-tooltip {
        background: #f8fafc;
        color: #0f172a;
      }
      html.dark-theme .social-tooltip::before {
        border-color: transparent #f8fafc transparent transparent;
      }

      /* Mobile adjustment */
      @media (max-width: 768px) {
        .social-sidebar {
          padding: 8px 5px;
          border-radius: 0 12px 12px 0;
          top: 60%; /* Position slightly lower on mobile to stay clear of other UI elements */
        }
        .social-item {
          width: 34px;
          height: 34px;
        }
        .social-item svg {
          width: 17px;
          height: 17px;
        }
        .social-tooltip {
          display: none; /* Hide tooltips on mobile since there's no hover */
        }
      }
    </style>

