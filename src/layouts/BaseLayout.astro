    <!-- Client-side script to handle social sidebar toggle and persistence -->
    <script is:inline>
      function initSocialSidebar() {
        const sidebar = document.getElementById('social-sidebar');
        if (!sidebar) return;

        const storedState = sessionStorage.getItem('social-sidebar-state');
        const isMobile = window.innerWidth < 768;

        if (storedState) {
          if (storedState === 'collapsed') {
            sidebar.classList.add('collapsed');
          } else {
            sidebar.classList.remove('collapsed');
          }
        } else {
          // Collapse by default on mobile, expand on desktop
          if (isMobile) {
            sidebar.classList.add('collapsed');
          } else {
            sidebar.classList.remove('collapsed');
          }
        }
      }

      // Initial execution
      initSocialSidebar();

      // Listeners for standard load, back/forward cache, and astro route changes
      document.addEventListener('DOMContentLoaded', initSocialSidebar);
      document.addEventListener('astro:after-swap', initSocialSidebar);

      // Delegate click listener to avoid duplicate bindings during route transitions
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('#social-sidebar-toggle');
        if (btn) {
          const sidebar = document.getElementById('social-sidebar');
          if (sidebar) {
            sidebar.classList.toggle('collapsed');
            const newState = sidebar.classList.contains('collapsed') ? 'collapsed' : 'expanded';
            sessionStorage.setItem('social-sidebar-state', newState);
          }
        }
      });
    </script>
