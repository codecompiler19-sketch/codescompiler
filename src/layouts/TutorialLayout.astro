---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  category: string;
  categoryLabel: string;
  headings?: { depth: number; slug: string; text: string }[];
  currentSlug?: string;
  seoTitle?: string;
}

const { title, description, category, categoryLabel, headings = [], currentSlug: propCurrentSlug, seoTitle } = Astro.props;

// Get all tutorials for the current category to build the sidebar
const tutorials = await getCollection('tutorials');
const categoryTutorials = tutorials
  .filter(t => t.data.category === category)
  .sort((a, b) => a.data.order - b.data.order);

const currentSlug = propCurrentSlug || Astro.url.pathname.replace(/\/$/, '').split('/').pop();

// Build grouped sidebar structure
type TutorialEntry = (typeof categoryTutorials)[number];
const sidebarGroups: { label: string | null; items: TutorialEntry[] }[] = [];
for (const t of categoryTutorials) {
  const g = t.data.group ?? null;
  const last = sidebarGroups[sidebarGroups.length - 1];
  if (!last || last.label !== g) {
    sidebarGroups.push({ label: g, items: [t] });
  } else {
    last.items.push(t);
  }
}

// UI colors for categories
const CATEGORY_COLORS: Record<string, { bg: string; text: string }> = {
  html: { bg: 'bg-orange-100', text: 'text-orange-700' },
  css: { bg: 'bg-blue-100', text: 'text-blue-700' },
  javascript: { bg: 'bg-yellow-100', text: 'text-yellow-700' },
  seo: { bg: 'bg-green-100', text: 'text-green-700' },
  python: { bg: 'bg-blue-100', text: 'text-blue-800' },
  sql: { bg: 'bg-[#dbeafe]', text: 'text-[#336791]' },
  php: { bg: 'bg-indigo-100', text: 'text-indigo-800' },
};
const catColor = CATEGORY_COLORS[category] ?? { bg: 'bg-gray-100', text: 'text-gray-700' };

// Table of Contents (H2 and H3 only)
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);

// ── SCHEMA.ORG JSON-LD ─────────────────────────────────────
const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://app.codescompiler.com';
const fullUrl = `${siteUrl}/tutorial/${currentSlug}`;

const tutorialSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "CodesCompiler"
  },
  "publisher": {
    "@type": "Organization",
    "name": "CodesCompiler",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/favicon.svg`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": fullUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": `${categoryLabel} Tutorial`, "item": `${siteUrl}/tutorial/${category}-introduction` },
    { "@type": "ListItem", "position": 3, "name": title, "item": fullUrl }
  ]
};

const schemaData = [tutorialSchema, breadcrumbSchema];
---

<BaseLayout title={title} description={description} schemaData={schemaData}>
  <!-- TUTORIAL SUB-HEADER FOR MOBILE SIDEBAR -->
  <div slot="sub-header" class="md:hidden bg-gray-50 flex items-center px-3 py-2 border-b border-gray-200 w-full relative z-10 shadow-sm">
    <button id="sidebar-toggle" class="p-1.5 mr-2 rounded hover:bg-gray-200 transition-colors text-gray-700" aria-label="Toggle sidebar">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
    <nav class="text-[11px] text-gray-500 flex items-center gap-1.5 flex-wrap font-medium" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#04AA6D] transition-colors">Home</a>
      <span>/</span>
      <a href={`/tutorial/${category}-introduction`} class="hover:text-[#04AA6D] transition-colors capitalize">{category}</a>
      <span>/</span>
      <span class="text-gray-900 font-semibold truncate max-w-[140px]">{title}</span>
    </nav>
  </div>

  <div class="w-full" style="max-width: 1600px; margin: 0 auto;">
  <div class="flex-1 flex overflow-hidden" style="min-height: 0;">
    <!-- Sidebar -->
    <aside
      id="page-sidebar"
      class="fixed top-[150px] bottom-0 left-0 z-50 md:z-0 w-64 bg-white border-r border-gray-100 transform -translate-x-full transition-transform duration-200 ease-in-out md:relative md:top-0 md:translate-x-0 overflow-y-auto"
    >
      <!-- Category badge -->
      <div class="px-3 py-3 border-b border-gray-200 bg-gray-50 sticky top-0">
        <span class={`inline-block text-xs font-bold uppercase tracking-widest px-2 py-1 rounded ${catColor.bg} ${catColor.text}`}>
          {categoryLabel} Tutorial
        </span>
      </div>

      <!-- Chapter links with optional group headers -->
      <nav class="py-2 flex flex-col" aria-label={`${categoryLabel} chapters`}>
        {sidebarGroups.map((group) => (
          <>
            {group.label && (
              <div class="px-4 pt-4 pb-1 text-[0.7rem] font-extrabold uppercase tracking-widest text-gray-400 select-none">
                {group.label}
              </div>
            )}
            {group.items.map((tutorial) => {
              const tutorialSlug = tutorial.data.permalink || tutorial.slug;
              const isActive = tutorialSlug === currentSlug;
              return (
                <a
                  href={`/tutorial/${tutorialSlug}`}
                  aria-current={isActive ? 'page' : undefined}
                  class={`block px-4 py-1.5 text-[0.82rem] font-medium border-l-4 transition-colors ${
                    isActive
                      ? 'border-[#04AA6D] bg-[#04AA6D] text-white'
                      : 'border-transparent text-gray-600 hover:bg-gray-50 hover:text-[#04AA6D]'
                  }`}
                >
                  {tutorial.data.title}
                </a>
              );
            })}
          </>
        ))}
      </nav>
    </aside>

    <!-- Overlay backdrop -->
    <div
      id="sidebar-backdrop"
      class="fixed top-[150px] bottom-0 left-0 right-0 bg-black/50 z-30 hidden md:hidden"
    ></div>

    <div class="flex flex-1 min-w-0">
      <!-- Article -->
      <article class="flex-1 min-w-0 px-5 sm:px-8 lg:px-14 py-8 bg-white">
        <!-- Breadcrumb (Desktop Only) -->
        <nav class="hidden md:flex text-xs text-gray-400 mb-6 items-center gap-1 flex-wrap" aria-label="Breadcrumb">
          <a href="/" class="hover:text-[#04AA6D] transition-colors">Home</a>
          <span>/</span>
          <a href={`/tutorial/${category}-introduction`} class="hover:text-[#04AA6D] transition-colors capitalize">{category}</a>
          <span>/</span>
          <span class="text-gray-600 truncate max-w-[180px]">{title}</span>
        </nav>

        <!-- Page Title & Description -->
        <div class="mb-6 pb-5 border-b border-gray-100">
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">{seoTitle || title}</h1>
          <p class="text-base text-gray-500">{description}</p>
        </div>

        <!-- Table of Contents -->
        {toc.length > 0 && (
          <div class="mb-10 p-6 bg-[#1b1b2f] rounded-xl border-l-4 border-[#04AA6D] shadow-md">
            <h4 class="text-sm font-extrabold text-white uppercase tracking-widest mb-4 flex items-center gap-2">
              <svg width="18" height="18" fill="none" stroke="#04AA6D" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/>
              </svg>
              Table of Contents
            </h4>
            <ul class="space-y-2">
              {toc.map(heading => (
                <li class={heading.depth === 3 ? "pl-5 text-[13.5px]" : "text-[14.5px] font-medium"}>
                  <a href={`#${heading.slug}`} class="text-gray-300 hover:text-[#04AA6D] transition-colors">
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Prose Content -->
        <div class="prose prose-gray prose-sm sm:prose-base max-w-none
          prose-headings:font-bold prose-headings:text-gray-900
          prose-a:text-[#04AA6D] prose-a:no-underline hover:prose-a:underline
          prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-[#c7254e] prose-code:text-sm prose-code:font-normal
          prose-pre:bg-[#282A35] prose-pre:text-gray-100 prose-pre:rounded-lg
          prose-blockquote:border-[#04AA6D] prose-blockquote:bg-green-50 prose-blockquote:py-1
          prose-li:text-gray-700">
          <slot />
        </div>

        <!-- Prev / Next -->
        {(() => {
          const idx = categoryTutorials.findIndex(t => t.slug === currentSlug);
          const prev = idx > 0 ? categoryTutorials[idx - 1] : null;
          const next = idx < categoryTutorials.length - 1 ? categoryTutorials[idx + 1] : null;

          if (!prev && !next) return null;

          return (
            <div class="mt-12 pt-8 border-t border-gray-100 flex items-center justify-between">
              {prev &&
                <a href={`/tutorial/${prev.data.permalink || prev.slug}`} class="flex items-center gap-2 text-sm font-semibold text-gray-500 hover:text-[#04AA6D] transition-colors">
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                  {prev.data.title}
                </a>
              }
              {next &&
                <a href={`/tutorial/${next.data.permalink || next.slug}`} class="flex items-center gap-2 text-sm font-semibold text-[#04AA6D] hover:underline ml-auto">
                  {next.data.title}
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
              }
            </div>
          );
        })()}
      </article>

      <!-- Right Sidebar (Ads & related) -->
      <aside class="hidden xl:block w-72 flex-shrink-0 pt-8 pr-8 pb-8">
        <div class="sticky top-20 flex flex-col gap-6">
          <AdSlot format="vertical" />
        </div>
      </aside>
    </div>
  </div>
  </div>

  <script is:inline>
    (function () {
      const btn      = document.getElementById('sidebar-toggle');
      const sidebar  = document.getElementById('page-sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');
      if (!btn || !sidebar || !backdrop) return;
      function openSidebar() {
        sidebar.classList.remove('-translate-x-full');
        sidebar.classList.add('translate-x-0');
        backdrop.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      function closeSidebar() {
        sidebar.classList.add('-translate-x-full');
        sidebar.classList.remove('translate-x-0');
        backdrop.classList.add('hidden');
        document.body.style.overflow = '';
      }
      btn.addEventListener('click', () => {
        const isOpen = !sidebar.classList.contains('-translate-x-full');
        if (isOpen) { closeSidebar(); } else { openSidebar(); }
      });
      backdrop.addEventListener('click', closeSidebar);
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768) {
          backdrop.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });
    })();
  </script>
</BaseLayout>
