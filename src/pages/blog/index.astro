---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';

const allPosts = await getCollection('blog');
const sorted   = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Filter by URL params (client-side filtering via JS)
const featured   = sorted.filter(p => p.data.featured);
const recentPosts = sorted.slice(0, 6);

// Category counts
const CATEGORY_MAP: Record<string, { color: string; bg: string; icon: string }> = {
  'HTML & CSS':          { color: '#E34F26', bg: '#fff4f0', icon: '🎨' },
  'JavaScript':          { color: '#ca8a04', bg: '#fefce8', icon: '⚡' },
  'JavaScript Projects': { color: '#eab308', bg: '#fef9c3', icon: '🚀' },
  'Login Form':          { color: '#3b82f6', bg: '#eff6ff', icon: '🔐' },
  'Card Design':         { color: '#8b5cf6', bg: '#f5f3ff', icon: '🃏' },
  'Navigation Bar':      { color: '#ec4899', bg: '#fdf2f8', icon: '🧭' },
  'Blog':                { color: '#10b981', bg: '#ecfdf5', icon: '📝' },
  'Website Designs':     { color: '#06b6d4', bg: '#ecfeff', icon: '🌐' },
  'Image Slider':        { color: '#f97316', bg: '#fff7ed', icon: '🖼️' },
  'API Projects':        { color: '#6366f1', bg: '#eef2ff', icon: '🔌' },
  'Sidebar Menu':        { color: '#84cc16', bg: '#f7fee7', icon: '📋' },
  'CSS Buttons':         { color: '#f43f5e', bg: '#fff1f2', icon: '🔘' },
  'JavaScript Games':    { color: '#a855f7', bg: '#faf5ff', icon: '🎮' },
  'Preloader or Loader': { color: '#0ea5e9', bg: '#f0f9ff', icon: '⏳' },
  'Form Validation':     { color: '#14b8a6', bg: '#f0fdfa', icon: '✅' },
  'Accordion':           { color: '#e11d48', bg: '#ffe4e6', icon: '🪗' },
  'Bootstrap':           { color: '#7e22ce', bg: '#faf5ff', icon: '🅱' },
  'Tabs':                { color: '#0369a1', bg: '#e0f2fe', icon: '🗂' },
  'Calendar':            { color: '#b91c1c', bg: '#fef2f2', icon: '📅' }
};

const cats = Object.keys(CATEGORY_MAP);
const catCounts = cats.reduce((acc, c) => {
  acc[c] = allPosts.filter(p => p.data.category === c).length;
  return acc;
}, {} as Record<string, number>);

// All unique tags
const allTags = [...new Set(allPosts.flatMap(p => p.data.tags ?? []))].sort();
---

<BaseLayout
  title="Posts | CodesCompiler"
  description="Explore coding projects, UI designs, and web development tutorials. Build real HTML, CSS, and JavaScript projects step by step."
>
  <!-- ============================================================ -->
  <!-- PAGE HERO                                                     -->
  <!-- ============================================================ -->
  <section class="posts-hero">
    <div class="posts-hero-inner">
      <span class="posts-hero-badge">💡 Coding Projects & Designs</span>
      <h1>Posts & Coding Examples</h1>
      <p>Real HTML, CSS &amp; JavaScript projects you can build yourself — with full source code included.</p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- MAIN THREE-COLUMN BODY                                        -->
  <!-- ============================================================ -->
  <div class="posts-container posts-body">

    <!-- Mobile sidebar toggle -->
    <button class="mob-sidebar-btn" id="mobSidebarToggle" aria-label="Open sidebar">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      Filter &amp; Categories
    </button>

    <!-- ── LEFT SIDEBAR ───────────────────────────────────────── -->
    <aside class="posts-sidebar" id="postsSidebar">

      <!-- Search -->
      <div class="sidebar-widget">
        <h3 class="widget-title">🔍 Search Posts</h3>
        <div class="search-box">
          <input
            type="text"
            id="postSearch"
            placeholder="Search..."
            class="search-input"
            autocomplete="off"
          />
          <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
      </div>

      <!-- Categories -->
      <div class="sidebar-widget">
        <h3 class="widget-title">📂 Categories</h3>
        <ul class="category-list">
          <li>
            <button class="cat-btn active" data-cat="all">
              <span class="cat-icon">🌐</span>
              <span class="cat-name">All Posts</span>
              <span class="cat-count">{allPosts.length}</span>
            </button>
          </li>
          {cats.map(cat => (
            <li>
              <button
                class="cat-btn"
                data-cat={cat}
                style={`--cc:${CATEGORY_MAP[cat].color};--cb:${CATEGORY_MAP[cat].bg}`}
              >
                <span class="cat-icon">{CATEGORY_MAP[cat].icon}</span>
                <span class="cat-name">{cat}</span>
                <span class="cat-count">{catCounts[cat] ?? 0}</span>
              </button>
            </li>
          ))}
        </ul>
      </div>

      <!-- Recent Posts -->
      <div class="sidebar-widget">
        <h3 class="widget-title">🕒 Recent Posts</h3>
        <ul class="recent-list">
          {recentPosts.map(post => (
            <li class="recent-item">
              <a href={`/blog/${post.slug}`} class="recent-link">
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="recent-thumb"
                    loading="lazy"
                    width="56"
                    height="56"
                  />
                )}
                <div class="recent-info">
                  <span class="recent-title">{post.data.title}</span>
                  <span class="recent-date">
                    {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Tags -->
      {allTags.length > 0 && (
        <div class="sidebar-widget">
          <h3 class="widget-title">🏷️ Popular Tags</h3>
          <div class="tag-cloud">
            {allTags.map(tag => (
              <button class="tag-pill" data-tag={tag}>#{tag}</button>
            ))}
          </div>
        </div>
      )}
    </aside>

    <!-- ── MAIN POSTS AREA ─────────────────────────────────────── -->
    <main class="posts-main">

      <!-- Featured Post (first featured) -->
      {featured.length > 0 && (
        <div class="featured-section">
          <div class="section-label">⭐ Featured Post</div>
          <a href={`/blog/${featured[0].slug}`} class="featured-card">
            {featured[0].data.image && (
              <div class="featured-img-wrap">
                <img
                  src={featured[0].data.image}
                  alt={featured[0].data.title}
                  class="featured-img"
                  width="700"
                  height="370"
                />
              </div>
            )}
            <div class="featured-body">
              {featured[0].data.category && (
                <span
                  class="post-badge"
                  style={`color:${CATEGORY_MAP[featured[0].data.category]?.color ?? '#666'};background:${CATEGORY_MAP[featured[0].data.category]?.bg ?? '#f3f4f6'}`}
                >
                  {featured[0].data.category}
                </span>
              )}
              <h2 class="featured-title">{featured[0].data.title}</h2>
              <p class="featured-desc">{featured[0].data.description}</p>
              <div class="featured-meta">
                <span>📅 {new Date(featured[0].data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                <span class="read-more">Read Post →</span>
              </div>
            </div>
          </a>
        </div>
      )}

      <!-- Posts Grid Header -->
      <div class="grid-header">
        <span class="section-label">📰 All Posts</span>
        <span class="post-count" id="postCount">{sorted.length} posts</span>
      </div>

      <!-- No results message -->
      <div id="noResults" class="no-results hidden">
        <span>🔍</span>
        <p>No posts found. Try a different search or category.</p>
      </div>

      <!-- Cards Grid -->
      <div class="posts-grid" id="postsGrid">
        {sorted.map(post => (
          <a
            href={`/blog/${post.slug}`}
            class="post-card"
            data-category={post.data.category}
            data-tags={JSON.stringify(post.data.tags ?? [])}
            data-title={post.data.title.toLowerCase()}
          >
            {post.data.image ? (
              <div class="card-img-wrap">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="card-img"
                  loading="lazy"
                  width="400"
                  height="210"
                />
              </div>
            ) : (
              <div class="card-img-placeholder">
                <span>💻</span>
              </div>
            )}
            <div class="card-body">
              <div class="card-meta-top">
                {post.data.category && (
                  <span
                    class="post-badge"
                    style={`color:${CATEGORY_MAP[post.data.category]?.color ?? '#666'};background:${CATEGORY_MAP[post.data.category]?.bg ?? '#f3f4f6'}`}
                  >
                    {post.data.category}
                  </span>
                )}
                <span class="card-date">
                  {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
              </div>
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-desc">{post.data.description}</p>
              <div class="card-footer">
                {(post.data.tags ?? []).slice(0, 3).map(t => (
                  <span class="card-tag">#{t}</span>
                ))}
                <span class="card-link">Read More →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Pagination Controls -->
      <div id="paginationContainer" class="pagination-container hidden">
        <button id="prevPage" class="page-btn">← Prev</button>
        <span id="pageInfo" class="page-info">Page 1 of 1</span>
        <button id="nextPage" class="page-btn">Next →</button>
      </div>

    </main>

    <!-- ── RIGHT AD COLUMN ─────────────────────────────────────── -->
    <aside class="posts-ad-col">
      <div class="ad-sticky-wrap">
        <AdSlot format="rectangle" />
        <div style="height:20px"></div>
        <AdSlot format="rectangle" />
      </div>
    </aside>

  </div><!-- /posts-body -->
</BaseLayout>

<!-- ================================================================ -->
<!-- CLIENT-SIDE FILTER/SEARCH JS                                      -->
<!-- ================================================================ -->
<script is:inline>
  const grid       = document.getElementById('postsGrid');
  const countEl    = document.getElementById('postCount');
  const noResults  = document.getElementById('noResults');
  const catBtns    = document.querySelectorAll('.cat-btn');
  const tagBtns    = document.querySelectorAll('.tag-pill');
  const searchinp  = document.getElementById('postSearch');
  
  const pagContainer = document.getElementById('paginationContainer');
  const prevBtn      = document.getElementById('prevPage');
  const nextBtn      = document.getElementById('nextPage');
  const pageInfo     = document.getElementById('pageInfo');

  let activeCat  = 'all';
  let activeTag  = null;
  let searchTerm = '';
  
  // Pagination State
  let currentPage = 1;
  const itemsPerPage = 9;
  let totalPages = 1;

  function filterCards() {
    const cards = Array.from(grid.querySelectorAll('.post-card'));
    const matchedCards = [];

    cards.forEach(card => {
      const cat   = card.dataset.category;
      const tags  = JSON.parse(card.dataset.tags || '[]');
      const title = card.dataset.title || '';
      const matchCat  = activeCat  === 'all' || cat === activeCat;
      const matchTag  = !activeTag || tags.includes(activeTag);
      const matchSrch = !searchTerm || title.includes(searchTerm);
      if (matchCat && matchTag && matchSrch) {
        matchedCards.push(card);
      } else {
        card.style.display = 'none';
      }
    });

    const visible = matchedCards.length;
    countEl.textContent = visible + ' post' + (visible !== 1 ? 's' : '');
    noResults.classList.toggle('hidden', visible > 0);

    // Pagination Logic
    totalPages = Math.ceil(visible / itemsPerPage) || 1;
    if (currentPage > totalPages) currentPage = 1; // reset if out of bounds

    const startIndex = (currentPage - 1) * itemsPerPage;
    const endIndex = startIndex + itemsPerPage;

    matchedCards.forEach((card, index) => {
      if (index >= startIndex && index < endIndex) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });

    // Update Pagination UI
    if (totalPages > 1) {
      pagContainer.classList.remove('hidden');
      pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
      prevBtn.disabled = currentPage === 1;
      nextBtn.disabled = currentPage === totalPages;
    } else {
      pagContainer.classList.add('hidden');
    }
  }

  prevBtn.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      filterCards();
      window.scrollTo({ top: grid.offsetTop - 120, behavior: 'smooth' });
    }
  });

  nextBtn.addEventListener('click', () => {
    if (currentPage < totalPages) {
      currentPage++;
      filterCards();
      window.scrollTo({ top: grid.offsetTop - 120, behavior: 'smooth' });
    }
  });

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      catBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCat = btn.dataset.cat;
      activeTag = null;
      currentPage = 1;
      tagBtns.forEach(t => t.classList.remove('active'));
      filterCards();
    });
  });

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;
      if (activeTag === tag) {
        activeTag = null;
        btn.classList.remove('active');
      } else {
        activeTag = tag;
        tagBtns.forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
      }
      currentPage = 1;
      filterCards();
    });
  });

  searchinp.addEventListener('input', e => {
    searchTerm = e.target.value.toLowerCase().trim();
    currentPage = 1;
    filterCards();
  });
  
  // Initialize
  filterCards();
</script>

<!-- ================================================================ -->
<!-- STYLES                                                            -->
<!-- ================================================================ -->
<style>
  /* ── Hero ────────────────────────────────────────────────────── */
  .posts-hero {
    background: linear-gradient(135deg, #282A35 0%, #1a1b26 100%);
    padding: 48px 20px 40px;
    text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .posts-hero-inner { max-width: 640px; margin: 0 auto; }
  .posts-hero-badge {
    display: inline-block;
    background: rgba(4,170,109,0.15);
    border: 1px solid rgba(4,170,109,0.3);
    color: #04AA6D;
    font-size: 12px;
    font-weight: 700;
    padding: 5px 16px;
    border-radius: 20px;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .posts-hero h1   { font-size: clamp(26px, 4vw, 36px); font-weight: 900; color: #fff; margin-bottom: 10px; }
  .posts-hero p    { font-size: 16px; color: rgba(255,255,255,0.55); line-height: 1.6; }

  /* ── Layout ──────────────────────────────────────────────────── */
  .posts-container {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .posts-body {
    display: grid;
    grid-template-columns: 260px 1fr 300px;
    gap: 28px;
    align-items: start;
    padding-top: 28px;
    padding-bottom: 56px;
  }
  @media (max-width: 1200px) { .posts-body { grid-template-columns: 240px 1fr; } .posts-ad-col { display: none; } }
  @media (max-width: 768px)  { .posts-body { grid-template-columns: 1fr; } .posts-sidebar { display: none; } }

  /* ── LEFT SIDEBAR ────────────────────────────────────────────── */
  .posts-sidebar {
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #e5e7eb transparent;
  }
  .posts-sidebar::-webkit-scrollbar { width: 4px; }
  .posts-sidebar::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 4px; }

  .sidebar-widget {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 18px;
    margin-bottom: 18px;
  }
  .widget-title {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #374151;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 2px solid #f3f4f6;
  }

  /* Search */
  .search-box { position: relative; }
  .search-input {
    width: 100%;
    padding: 9px 36px 9px 12px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 13.5px;
    outline: none;
    background: #f9fafb;
    transition: border-color .2s;
  }
  .search-input:focus { border-color: #04AA6D; background: #fff; }
  .search-icon { position: absolute; right: 10px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: #9ca3af; pointer-events: none; }

  /* Category buttons */
  .category-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
  .cat-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 10px;
    border: none;
    background: none;
    border-radius: 8px;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    font-size: 13.5px;
    color: #374151;
    font-weight: 500;
    transition: background .15s;
  }
  .cat-btn:hover { background: #f3f4f6; }
  .cat-btn.active { background: #f0fdf4; color: #04AA6D; font-weight: 700; }
  .cat-btn.active .cat-count { background: #04AA6D; color: #fff; }
  .cat-icon { font-size: 15px; }
  .cat-name { flex: 1; }
  .cat-count {
    font-size: 11px;
    font-weight: 700;
    background: #f3f4f6;
    color: #6b7280;
    padding: 2px 8px;
    border-radius: 20px;
    min-width: 24px;
    text-align: center;
  }

  /* Recent Posts */
  .recent-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .recent-link { display: flex; align-items: flex-start; gap: 10px; text-decoration: none; color: inherit; }
  .recent-thumb { width: 56px; height: 56px; border-radius: 8px; object-fit: cover; flex-shrink: 0; border: 1px solid #f3f4f6; }
  .recent-info { display: flex; flex-direction: column; gap: 3px; }
  .recent-title { font-size: 13px; font-weight: 600; color: #1f2937; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; transition: color .15s; }
  .recent-link:hover .recent-title { color: #04AA6D; }
  .recent-date { font-size: 11px; color: #9ca3af; }

  /* Tags */
  .tag-cloud { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag-pill {
    font-size: 12px;
    font-weight: 600;
    color: #04AA6D;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    padding: 4px 10px;
    border-radius: 20px;
    cursor: pointer;
    font-family: inherit;
    transition: background .15s, color .15s;
  }
  .tag-pill:hover, .tag-pill.active { background: #04AA6D; color: #fff; border-color: #04AA6D; }

  /* ── MAIN POSTS AREA ──────────────────────────────────────────── */
  .posts-main { min-width: 0; }

  .section-label {
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #04AA6D;
    margin-bottom: 12px;
    display: block;
  }

  /* Featured card */
  .featured-section { margin-bottom: 32px; }
  .featured-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow .25s, transform .25s;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  .featured-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,.12); transform: translateY(-3px); }
  @media (min-width: 640px) { .featured-card { flex-direction: row; } }
  .featured-img-wrap { flex-shrink: 0; }
  @media (min-width: 640px) { .featured-img-wrap { width: 46%; } }
  .featured-img { width: 100%; height: 240px; object-fit: cover; display: block; }
  @media (min-width: 640px) { .featured-img { height: 100%; } }
  .featured-body { padding: 24px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
  .featured-title { font-size: clamp(18px, 2.5vw, 22px); font-weight: 800; color: #111827; line-height: 1.3; }
  .featured-desc  { font-size: 14px; color: #6b7280; line-height: 1.65; flex: 1; }
  .featured-meta  { display: flex; align-items: center; justify-content: space-between; font-size: 13px; color: #9ca3af; }
  .read-more { color: #04AA6D; font-weight: 700; }

  /* Grid header */
  .grid-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .post-count { font-size: 13px; color: #9ca3af; font-weight: 600; }

  /* No results */
  .no-results {
    text-align: center;
    padding: 48px 20px;
    background: #f9fafb;
    border-radius: 16px;
    border: 1px solid #e5e7eb;
  }
  .no-results.hidden { display: none; }
  .no-results span { font-size: 40px; display: block; margin-bottom: 12px; }
  .no-results p { color: #6b7280; font-size: 15px; }

  /* Cards grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .post-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow .25s, transform .25s;
  }
  .post-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,.12); transform: translateY(-4px); }

  .card-img-wrap { overflow: hidden; height: 185px; }
  .card-img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; display: block; }
  .post-card:hover .card-img { transform: scale(1.04); }

  .card-img-placeholder {
    height: 140px;
    background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
  }

  .card-body { padding: 18px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .card-meta-top { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .card-date { font-size: 11px; color: #9ca3af; white-space: nowrap; }
  .card-title {
    font-size: 16px;
    font-weight: 800;
    color: #111827;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-desc {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .card-footer { display: flex; flex-wrap: wrap; align-items: center; gap: 6px; margin-top: auto; padding-top: 8px; border-top: 1px solid #f3f4f6; }
  .card-tag { font-size: 11px; font-weight: 600; color: #6b7280; background: #f3f4f6; padding: 2px 8px; border-radius: 4px; }
  .card-link { margin-left: auto; font-size: 12px; font-weight: 700; color: #04AA6D; }

  /* Pagination */
  .pagination-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 40px;
  }
  .pagination-container.hidden { display: none; }
  .page-info { font-size: 14px; font-weight: 700; color: #6b7280; }
  .page-btn {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 14px;
    font-weight: 700;
    color: #374151;
    cursor: pointer;
    transition: all .2s;
  }
  .page-btn:hover:not(:disabled) {
    border-color: #04AA6D;
    color: #04AA6D;
    background: #f0fdf4;
  }
  .page-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background: #f9fafb;
  }

  /* Shared badge */
  .post-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ── RIGHT AD ─────────────────────────────────────────────────── */
  .posts-ad-col { min-width: 0; }
  .ad-sticky-wrap { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 20px; }

  /* ── MOBILE SIDEBAR HAMBURGER ──────────────────────────────────── */
  .mob-sidebar-btn {
    display: none;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    color: #374151;
    cursor: pointer;
    font-family: inherit;
    transition: background .15s, border-color .15s;
    grid-column: 1 / -1;
    margin-bottom: 4px;
  }
  .mob-sidebar-btn:hover { background: #f9fafb; border-color: #04AA6D; color: #04AA6D; }
  @media (max-width: 768px) {
    .mob-sidebar-btn { display: flex; }
  }

  /* Mobile sidebar slide-in overlay */
  @media (max-width: 768px) {
    .posts-sidebar {
      display: block !important;
      position: fixed;
      top: 0; left: 0;
      width: min(300px, 85vw);
      height: 100dvh;
      background: #fff;
      z-index: 200;
      padding: 20px 16px;
      box-shadow: 4px 0 32px rgba(0,0,0,0.2);
      transform: translateX(-110%);
      transition: transform .28s cubic-bezier(0.4, 0, 0.2, 1);
      max-height: none;
      overflow-y: auto;
      top: 0;
    }
    .posts-sidebar.open { transform: translateX(0); }
    .mob-close-row {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 14px;
    }
    .mob-close-row button {
      display: flex; align-items: center; gap: 5px;
      padding: 7px 14px;
      background: #f3f4f6;
      border: none; border-radius: 8px;
      font-size: 12px; font-weight: 700; color: #374151;
      cursor: pointer; font-family: inherit;
    }
  }
  @media (min-width: 769px) { .mob-close-row { display: none !important; } }

  .mob-sidebar-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 199;
    backdrop-filter: blur(2px);
  }
  .mob-sidebar-overlay.show { display: block; }
</style>

<script is:inline>
  (function () {
    const btn     = document.getElementById('mobSidebarToggle');
    const sidebar = document.getElementById('postsSidebar');
    if (!btn || !sidebar) return;

    // Inject close button inside sidebar
    const closeRow = document.createElement('div');
    closeRow.className = 'mob-close-row';
    closeRow.innerHTML = '<button id="mobCloseBtn">✕ Close</button>';
    sidebar.prepend(closeRow);

    // Inject overlay
    const overlay = document.createElement('div');
    overlay.className = 'mob-sidebar-overlay';
    document.body.appendChild(overlay);

    function open()  { sidebar.classList.add('open'); overlay.classList.add('show'); document.body.style.overflow = 'hidden'; }
    function close() { sidebar.classList.remove('open'); overlay.classList.remove('show'); document.body.style.overflow = ''; }

    btn.addEventListener('click', open);
    document.getElementById('mobCloseBtn').addEventListener('click', close);
    overlay.addEventListener('click', close);
    window.addEventListener('resize', () => { if (window.innerWidth >= 769) close(); });
  })();
</script>
