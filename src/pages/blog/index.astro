---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogs = await getCollection('blog');
const sorted = blogs.sort((a, b) => new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime());
---

<BaseLayout title="Blog" description="Latest articles, tutorials, tips and guides on web development — HTML, CSS, JavaScript and more.">
  <div style="max-width:900px;margin:0 auto;padding:40px 20px">
    <h1 style="font-size:32px;font-weight:800;margin-bottom:8px">📰 Blog</h1>
    <p style="color:#6b7280;font-size:16px;margin-bottom:36px">Latest articles, tips, and guides on web development.</p>

    {sorted.length === 0 && (
      <div style="text-align:center;padding:60px 20px;background:#f9fafb;border-radius:12px;border:1px solid #e5e7eb">
        <p style="font-size:18px;color:#9ca3af">No blog posts yet. Check back soon!</p>
      </div>
    )}

    <div style="display:flex;flex-direction:column;gap:20px">
      {sorted.map(post => (
        <a href={`/blog/${post.slug}`} style="display:block;background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:24px;text-decoration:none;color:inherit;transition:all .2s"
           onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,.08)';this.style.transform='translateY(-2px)'"
           onmouseout="this.style.boxShadow='none';this.style.transform='none'">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
            {post.data.category && (
              <span style="background:#f3e8ff;color:#7c3aed;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;text-transform:uppercase">{post.data.category}</span>
            )}
            {post.data.date && (
              <span style="font-size:12px;color:#9ca3af">{new Date(post.data.date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}</span>
            )}
          </div>
          <h2 style="font-size:20px;font-weight:700;color:#111827;margin-bottom:8px;line-height:1.3">{post.data.title}</h2>
          <p style="font-size:14px;color:#6b7280;line-height:1.6;margin:0">{post.data.description}</p>
          {post.data.author && (
            <p style="font-size:12px;color:#9ca3af;margin-top:12px">By {post.data.author}</p>
          )}
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
