---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const blogs = await getCollection('blog');
  return blogs.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const allBlogs = await getCollection('blog');
const sorted = allBlogs.sort((a, b) => new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime());
const currentIdx = sorted.findIndex(p => p.slug === post.slug);
const prevPost = currentIdx < sorted.length - 1 ? sorted[currentIdx + 1] : null;
const nextPost = currentIdx > 0 ? sorted[currentIdx - 1] : null;
---

<BaseLayout
  title={post.data.seoTitle || post.data.title}
  description={post.data.description}
>
  <article style="max-width:780px;margin:0 auto;padding:40px 20px">
    <!-- Breadcrumb -->
    <nav style="font-size:13px;color:#9ca3af;margin-bottom:20px">
      <a href="/" style="color:#04AA6D;text-decoration:none">Home</a>
      <span style="margin:0 6px">›</span>
      <a href="/blog" style="color:#04AA6D;text-decoration:none">Blog</a>
      <span style="margin:0 6px">›</span>
      <span style="color:#6b7280">{post.data.title}</span>
    </nav>

    <!-- Meta -->
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap">
      {post.data.category && (
        <span style="background:#f3e8ff;color:#7c3aed;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;text-transform:uppercase">{post.data.category}</span>
      )}
      {post.data.date && (
        <span style="font-size:13px;color:#9ca3af">{new Date(post.data.date).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}</span>
      )}
      {post.data.author && (
        <span style="font-size:13px;color:#6b7280">by <strong>{post.data.author}</strong></span>
      )}
    </div>

    <h1 style="font-size:32px;font-weight:800;line-height:1.3;margin-bottom:12px;color:#111827">{post.data.title}</h1>
    <p style="font-size:17px;color:#6b7280;line-height:1.6;margin-bottom:32px">{post.data.description}</p>

    <hr style="border:none;border-top:1px solid #e5e7eb;margin-bottom:32px"/>

    <!-- Blog Content -->
    <div class="blog-content" style="font-size:16px;line-height:1.8;color:#374151">
      <Content />
    </div>

    <hr style="border:none;border-top:1px solid #e5e7eb;margin:40px 0"/>

    <!-- Prev / Next Navigation -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} style="display:block;padding:16px;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:inherit;transition:all .2s"
           onmouseover="this.style.borderColor='#04AA6D'" onmouseout="this.style.borderColor='#e5e7eb'">
          <span style="font-size:11px;color:#9ca3af;text-transform:uppercase">← Previous</span>
          <div style="font-size:14px;font-weight:600;color:#111827;margin-top:4px">{prevPost.data.title}</div>
        </a>
      ) : <div></div>}
      {nextPost ? (
        <a href={`/blog/${nextPost.slug}`} style="display:block;padding:16px;border:1px solid #e5e7eb;border-radius:10px;text-decoration:none;color:inherit;text-align:right;transition:all .2s"
           onmouseover="this.style.borderColor='#04AA6D'" onmouseout="this.style.borderColor='#e5e7eb'">
          <span style="font-size:11px;color:#9ca3af;text-transform:uppercase">Next →</span>
          <div style="font-size:14px;font-weight:600;color:#111827;margin-top:4px">{nextPost.data.title}</div>
        </a>
      ) : <div></div>}
    </div>

    <!-- Back to Blog -->
    <div style="text-align:center;margin-top:32px">
      <a href="/blog" style="display:inline-block;padding:10px 24px;background:#04AA6D;color:#fff;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px">← All Blog Posts</a>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .blog-content h2 { font-size: 24px; font-weight: 700; margin: 32px 0 12px; color: #111827; }
  .blog-content h3 { font-size: 20px; font-weight: 600; margin: 24px 0 10px; color: #1f2937; }
  .blog-content p { margin-bottom: 16px; }
  .blog-content ul, .blog-content ol { margin: 12px 0 16px 24px; }
  .blog-content li { margin-bottom: 6px; }
  .blog-content code { background: #f3f4f6; padding: 2px 6px; border-radius: 4px; font-size: 14px; }
  .blog-content pre { background: #1e1e2e; color: #e4e4e7; padding: 16px; border-radius: 8px; overflow-x: auto; margin: 16px 0; }
  .blog-content pre code { background: transparent; padding: 0; }
  .blog-content blockquote { border-left: 4px solid #04AA6D; padding: 12px 20px; background: #f9fafb; border-radius: 0 8px 8px 0; margin: 16px 0; color: #374151; }
  .blog-content a { color: #04AA6D; text-decoration: underline; }
  .blog-content img { max-width: 100%; border-radius: 8px; margin: 16px 0; }
</style>
