---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="CodesCompiler | Learn HTML, CSS & JavaScript Free" 
  description="Free interactive web development tutorials for HTML, CSS, and JavaScript. Learn step-by-step with a live code editor. Perfect for beginners."
>

<!-- ============================================================ -->
<!--  HERO — animated gradient + floating code snippets           -->
<!-- ============================================================ -->
<section class="relative w-full overflow-hidden bg-[#282A35]">

  <!-- Animated grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(4,170,109,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(4,170,109,0.05)_1px,transparent_1px)] bg-[size:3rem_3rem]"></div>

  <!-- Glowing orbs -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#04AA6D]/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-purple-600/10 rounded-full blur-3xl pointer-events-none"></div>

  <!-- Floating code decorations (desktop only) -->
  <div class="hidden lg:block absolute top-12 left-6 font-mono text-xs text-[#04AA6D]/40 leading-relaxed select-none float-1">
    &lt;<span class="text-orange-400/50">html</span>&gt;<br/>
    &nbsp;&lt;<span class="text-orange-400/50">head</span>&gt;&lt;/<span class="text-orange-400/50">head</span>&gt;<br/>
    &nbsp;&lt;<span class="text-orange-400/50">body</span>&gt;<br/>
    &nbsp;&nbsp;&lt;<span class="text-orange-400/50">h1</span>&gt;Hello!&lt;/<span class="text-orange-400/50">h1</span>&gt;<br/>
    &nbsp;&lt;/<span class="text-orange-400/50">body</span>&gt;<br/>
    &lt;/<span class="text-orange-400/50">html</span>&gt;
  </div>
  <div class="hidden lg:block absolute top-16 right-6 font-mono text-xs text-blue-400/40 leading-relaxed select-none text-right float-2">
    <span class="text-purple-400/50">.hero</span> &#123;<br/>
    &nbsp;&nbsp;<span class="text-blue-300/50">display</span>: flex;<br/>
    &nbsp;&nbsp;<span class="text-blue-300/50">color</span>: <span class="text-green-400/50">#04AA6D</span>;<br/>
    &nbsp;&nbsp;<span class="text-blue-300/50">gap</span>: 1rem;<br/>
    &#125;
  </div>
  <div class="hidden xl:block absolute bottom-20 left-12 font-mono text-xs text-yellow-400/30 leading-relaxed select-none float-3">
    <span class="text-yellow-300/40">const</span> <span class="text-white/30">learn</span> = () =&gt; &#123;<br/>
    &nbsp;&nbsp;<span class="text-yellow-300/40">return</span> <span class="text-green-400/40">'success'</span>;<br/>
    &#125;;
  </div>

  <!-- Hero content -->
  <div class="relative z-10 max-w-5xl mx-auto px-5 py-24 sm:py-32 text-center">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-[#04AA6D]/10 border border-[#04AA6D]/30 rounded-full px-4 py-2 mb-8">
      <span class="w-2 h-2 rounded-full bg-[#04AA6D] animate-pulse"></span>
      <span class="text-[#04AA6D] text-sm font-semibold">Free · No Sign-up · Start Instantly</span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl font-black text-white leading-none tracking-tight mb-6">
      The Fastest Way to<br/>
      <span class="relative inline-block mt-2">
        <span class="relative z-10 text-transparent bg-clip-text bg-gradient-to-r from-[#04AA6D] to-emerald-300">Learn Web Dev</span>
        <span class="absolute -bottom-2 left-0 right-0 h-1 bg-gradient-to-r from-[#04AA6D] to-emerald-300 rounded-full opacity-50"></span>
      </span>
    </h1>

    <p class="text-gray-400 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed mb-10">
      Interactive, hands-on tutorials for <strong class="text-orange-400">HTML</strong>, <strong class="text-blue-400">CSS</strong>, and <strong class="text-yellow-400">JavaScript</strong>. 
      Write real code in the browser and see results instantly — no setup, no downloads.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="/tutorial/html-introduction"
         class="group w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-bold text-white bg-[#04AA6D] hover:bg-[#038a58] rounded-lg shadow-lg shadow-[#04AA6D]/20 hover:shadow-[#04AA6D]/40 hover:-translate-y-0.5 transition-all duration-200">
        Start Learning Free
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="#courses"
         class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold text-gray-300 border border-gray-600 hover:border-gray-400 hover:text-white rounded-lg transition-all duration-200">
        Browse All Courses
      </a>
    </div>

    <!-- Mini Code Preview Window -->
    <div class="max-w-2xl mx-auto bg-[#1a1b26] rounded-2xl border border-white/10 shadow-2xl overflow-hidden text-left">
      <div class="flex items-center gap-2 px-4 py-3 bg-[#13131e] border-b border-white/10">
        <span class="w-2.5 h-2.5 rounded-full bg-red-500/70"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/70"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-green-500/70"></span>
        <div class="flex-1 flex justify-center">
          <span class="text-gray-500 text-xs font-mono">index.html — CodesCompiler Try It Yourself</span>
        </div>
      </div>
      <div class="p-5 font-mono text-sm leading-relaxed">
        <div><span class="text-gray-500">1 </span><span class="text-orange-400">&lt;h1</span> <span class="text-yellow-300">style</span><span class="text-white">=</span><span class="text-green-400">"color:#04AA6D"</span><span class="text-orange-400">&gt;</span><span class="text-white">Hello, World!</span><span class="text-orange-400">&lt;/h1&gt;</span></div>
        <div><span class="text-gray-500">2 </span><span class="text-orange-400">&lt;p&gt;</span><span class="text-white">I am learning <span class="text-blue-300">HTML</span> at CodesCompiler.</span><span class="text-orange-400">&lt;/p&gt;</span></div>
        <div><span class="text-gray-500">3 </span><span class="text-orange-400">&lt;button</span> <span class="text-yellow-300">onclick</span><span class="text-white">=</span><span class="text-green-400">"alert('It works! 🎉')"</span><span class="text-orange-400">&gt;</span><span class="text-white">Click Me</span><span class="text-orange-400">&lt;/button&gt;</span></div>
        <div class="mt-2 pt-2 border-t border-white/5 text-gray-500 text-xs">▶ Output: <span class="text-white font-sans">Hello, World!</span> &nbsp; <span class="text-[#04AA6D]">I am learning HTML at CodesCompiler.</span> &nbsp; <span class="bg-gray-700 text-white px-2 py-0.5 rounded text-xs">Click Me</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================ -->
<!--  STATS STRIP                                                  -->
<!-- ============================================================ -->
<section class="w-full bg-[#04AA6D]">
  <div class="max-w-5xl mx-auto px-5 py-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center text-white">
    {[
      { v: '50+',  l: 'Tutorial Chapters', icon: '📖' },
      { v: '200+', l: 'Code Examples',     icon: '💻' },
      { v: '3',    l: 'Learning Paths',    icon: '🛤️'  },
      { v: '$0',   l: 'Always Free',       icon: '🎁'  },
    ].map(s => (
      <div class="flex flex-col items-center gap-1">
        <span class="text-2xl">{s.icon}</span>
        <div class="text-3xl font-black">{s.v}</div>
        <div class="text-green-100 text-sm">{s.l}</div>
      </div>
    ))}
  </div>
</section>

<!-- ============================================================ -->
<!--  HOW IT WORKS                                                 -->
<!-- ============================================================ -->
<section class="w-full bg-white py-20 px-5">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <span class="text-[#04AA6D] text-xs font-bold uppercase tracking-widest">Simple Process</span>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mt-2">How CodesCompiler Works</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-8 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-[#04AA6D]/30 via-[#04AA6D] to-[#04AA6D]/30"></div>
      {[
        { step: '01', title: 'Choose a Topic', desc: 'Pick from HTML, CSS, or JavaScript. Start from chapter 1 or jump to any specific topic.', color: 'bg-orange-100 text-orange-600' },
        { step: '02', title: 'Read & Learn', desc: "Each chapter explains a concept clearly with real-world examples. No fluff, no jargon.", color: 'bg-blue-100 text-blue-600' },
        { step: '03', title: 'Try It Yourself', desc: 'Every page has a live editor. Edit the code, click Run and see your changes instantly.', color: 'bg-emerald-100 text-emerald-600' },
      ].map(item => (
        <div class="relative flex flex-col items-center text-center p-6">
          <div class={`w-16 h-16 rounded-2xl ${item.color} flex items-center justify-center text-xl font-black mb-4 shadow-sm`}>
            {item.step}
          </div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">{item.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============================================================ -->
<!--  COURSE CARDS                                                 -->
<!-- ============================================================ -->
<section id="courses" class="w-full bg-gray-50 py-20 px-5 scroll-mt-20 border-t border-gray-100">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <span class="text-[#04AA6D] text-xs font-bold uppercase tracking-widest">Start Learning</span>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mt-2">Pick Your First Language</h2>
      <p class="text-gray-500 mt-3 max-w-lg mx-auto">Master the three fundamental technologies of the web. Every developer starts here.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- HTML -->
      <a href="/tutorial/html-introduction" id="course-html"
         class="group relative bg-white border-2 border-transparent hover:border-orange-300 rounded-2xl p-7 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden block">
        <div class="absolute top-0 right-0 w-24 h-24 bg-orange-50 rounded-full -translate-x-4 -translate-y-10 group-hover:scale-150 transition-transform duration-500"></div>
        <div class="relative">
          <div class="flex items-center justify-between mb-5">
            <div class="w-14 h-14 rounded-xl bg-orange-100 flex items-center justify-center">
              <span class="text-orange-600 font-black text-xl font-mono">&lt;/&gt;</span>
            </div>
            <span class="text-xs font-bold bg-orange-100 text-orange-600 px-3 py-1 rounded-full">Beginner</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">HTML</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">The skeleton of every webpage. Learn to structure content, create forms, add images, and build solid foundations.</p>
          <div class="flex items-center gap-3 text-xs text-gray-400 mb-5">
            <span class="flex items-center gap-1">📚 12 chapters</span>
            <span class="flex items-center gap-1">⏱ ~3 hours</span>
          </div>
          <div class="flex items-center text-sm font-bold text-orange-600 group-hover:gap-2 gap-1 transition-all">
            Start HTML
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

      <!-- CSS -->
      <a href="/tutorial/css-introduction" id="course-css"
         class="group relative bg-white border-2 border-transparent hover:border-blue-300 rounded-2xl p-7 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden block">
        <div class="absolute top-0 right-0 w-24 h-24 bg-blue-50 rounded-full -translate-x-4 -translate-y-10 group-hover:scale-150 transition-transform duration-500"></div>
        <div class="relative">
          <div class="flex items-center justify-between mb-5">
            <div class="w-14 h-14 rounded-xl bg-blue-100 flex items-center justify-center">
              <span class="text-blue-600 font-black text-xl font-mono">{ }</span>
            </div>
            <span class="text-xs font-bold bg-blue-100 text-blue-600 px-3 py-1 rounded-full">Step 2</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">CSS</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">Make your HTML beautiful. Master colors, layouts, Flexbox, Grid, animations, and fully responsive designs.</p>
          <div class="flex items-center gap-3 text-xs text-gray-400 mb-5">
            <span class="flex items-center gap-1">📚 15 chapters</span>
            <span class="flex items-center gap-1">⏱ ~4 hours</span>
          </div>
          <div class="flex items-center text-sm font-bold text-blue-600 group-hover:gap-2 gap-1 transition-all">
            Start CSS
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

      <!-- JS -->
      <a href="/tutorial/js-introduction" id="course-js"
         class="group relative bg-white border-2 border-transparent hover:border-yellow-300 rounded-2xl p-7 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden block">
        <div class="absolute top-0 right-0 w-24 h-24 bg-yellow-50 rounded-full -translate-x-4 -translate-y-10 group-hover:scale-150 transition-transform duration-500"></div>
        <div class="relative">
          <div class="flex items-center justify-between mb-5">
            <div class="w-14 h-14 rounded-xl bg-yellow-100 flex items-center justify-center">
              <span class="text-yellow-600 font-black text-xl font-mono">JS</span>
            </div>
            <span class="text-xs font-bold bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full">Step 3</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">JavaScript</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">Bring pages to life. Handle clicks, fetch APIs, build dynamic interfaces, and write real programs.</p>
          <div class="flex items-center gap-3 text-xs text-gray-400 mb-5">
            <span class="flex items-center gap-1">📚 18 chapters</span>
            <span class="flex items-center gap-1">⏱ ~6 hours</span>
          </div>
          <div class="flex items-center text-sm font-bold text-yellow-600 group-hover:gap-2 gap-1 transition-all">
            Start JavaScript
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- ============================================================ -->
<!--  FEATURES GRID                                               -->
<!-- ============================================================ -->
<section class="w-full bg-white py-20 px-5 border-t border-gray-100">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <span class="text-[#04AA6D] text-xs font-bold uppercase tracking-widest">Why Us</span>
      <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mt-2">Everything You Need to Succeed</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { emoji: '🖊️', title: 'Write Real Code', desc: 'Every chapter includes a live "Try It Yourself" editor — not just reading, but actually writing code.' },
        { emoji: '⚡', title: 'Instant Results', desc: 'See your code output immediately in a live preview pane. No compiling, no waiting, no setup.' },
        { emoji: '📱', title: 'Works on Any Device', desc: 'Study on your phone, tablet, or computer. Everything is fully responsive and mobile-friendly.' },
        { emoji: '🗺️', title: 'Clear Learning Path', desc: 'Chapters are ordered logically. Every concept builds on the last — zero confusion.' },
        { emoji: '🔍', title: 'Quick Reference', desc: 'Use the sidebar to jump to any topic anytime. Perfect for when you need a fast answer.' },
        { emoji: '🆓', title: 'Completely Free', desc: 'No sign-up. No credit card. No premium tier. Every tutorial, every example — always free.' },
      ].map(f => (
        <div class="flex gap-4 p-5 rounded-xl hover:bg-gray-50 transition-colors group">
          <div class="text-3xl flex-shrink-0 pt-0.5 group-hover:scale-110 transition-transform">{f.emoji}</div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">{f.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============================================================ -->
<!--  BOTTOM CTA                                                   -->
<!-- ============================================================ -->
<section class="w-full bg-[#282A35] py-20 px-5">
  <div class="max-w-3xl mx-auto text-center">
    <!-- Code snippet decoration -->
    <div class="inline-block bg-[#1a1b26] border border-white/10 rounded-lg px-6 py-3 font-mono text-sm mb-8">
      <span class="text-yellow-400">const</span>
      <span class="text-white"> you </span>
      <span class="text-gray-400">= </span>
      <span class="text-green-400">"a web developer"</span>
      <span class="text-gray-400">;</span>
      <span class="text-gray-500 ml-3">// starting now 🚀</span>
    </div>
    <h2 class="text-3xl sm:text-4xl font-black text-white mb-4 leading-tight">
      Your first line of code<br/>is one click away.
    </h2>
    <p class="text-gray-400 text-lg mb-10 max-w-xl mx-auto">
      Join thousands of learners who started their coding journey on CodesCompiler. No experience needed.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/tutorial/html-introduction" id="cta-html-btn"
         class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-10 py-4 text-base font-bold text-white bg-[#04AA6D] hover:bg-[#038a58] rounded-lg shadow-lg shadow-[#04AA6D]/20 hover:shadow-[#04AA6D]/40 hover:-translate-y-0.5 transition-all duration-200">
        Begin with HTML →
      </a>
      <a href="/about" class="text-gray-400 hover:text-white text-sm font-medium transition-colors underline underline-offset-4">
        Learn more about CodesCompiler
      </a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  @keyframes float1 {
    0%, 100% { transform: translateY(0)   rotate(-2deg); }
    50%       { transform: translateY(-14px) rotate(-2deg); }
  }
  @keyframes float2 {
    0%, 100% { transform: translateY(0)   rotate(2deg); }
    50%       { transform: translateY(10px) rotate(2deg); }
  }
  @keyframes float3 {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }
  .float-1 { animation: float1 8s ease-in-out infinite; }
  .float-2 { animation: float2 10s ease-in-out infinite; }
  .float-3 { animation: float3 7s ease-in-out infinite; }
  html { scroll-behavior: smooth; }
</style>
