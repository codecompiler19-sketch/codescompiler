---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Our Apps - Devotional & Fitness Android Apps by CodesCompiler" 
  description="Explore our range of premium Android apps including Shri Hanuman Chalisa, Naam Jap, Hanuman Bhakti, and Women Fitness Pro."
>
  <div class="max-w-6xl mx-auto py-12 px-4 sm:px-6 lg:px-8 my-8">
    
    <!-- Hero Banner Accent -->
    <div class="bg-gradient-to-r from-emerald-500 via-teal-600 to-cyan-600 rounded-3xl p-8 sm:p-12 text-white text-center shadow-lg mb-12 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#fff_1px,transparent_1px)] bg-[size:16px_16px]"></div>
      <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight mb-3">Our Apps Collection</h1>
      <p class="text-base sm:text-lg text-emerald-100 max-w-2xl mx-auto">
        Explore our curated collection of high-quality Android apps designed to enhance your spiritual devotion and daily fitness journeys.
      </p>
    </div>

    <!-- App Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <!-- 1. Naam Jap App -->
      <div class="bg-white border border-gray-150 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col p-6 sm:p-8">
        <div class="flex items-start gap-4 mb-4">
          <!-- Icon placeholder with nice colors -->
          <div class="w-16 h-16 bg-amber-500 text-white rounded-2xl flex items-center justify-center text-3xl font-bold shadow-md">
            📿
          </div>
          <div>
            <h2 class="text-xl font-bold text-gray-900">Naam Jap</h2>
            <p class="text-xs font-semibold text-amber-600 uppercase tracking-wider">Devotional & Meditation</p>
          </div>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed mb-6 flex-grow">
          A digital chanting counter designed to help you track your daily prayers and mantra recitations. Maintain your spiritual focus with features like haptic feedback, audio assistance, and progress tracking for peaceful meditation.
        </p>
        <a 
          href="https://play.google.com/store/apps/details?id=com.namjapp.app" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="inline-flex items-center justify-center gap-2.5 bg-zinc-900 hover:bg-zinc-800 text-white px-5 py-3 rounded-xl font-bold text-sm transition-all group mt-auto w-full sm:w-max"
        >
          <svg class="w-5 h-5 text-white fill-current" viewBox="0 0 512 512">
            <path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58 33.3-60.7-60.7 118.7 27.4c15.9 3.7 21.8 14.1 21.8 22.2 0 8.1-5.9 18.5-21.8 22.2zM325.3 277.7L385.4 338 104.6 499l220.7-221.3z"/>
          </svg>
          Get on Google Play
        </a>
      </div>

      <!-- 2. Shri Hanuman Chalisa App -->
      <div class="bg-white border border-gray-150 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col p-6 sm:p-8">
        <div class="flex items-start gap-4 mb-4">
          <div class="w-16 h-16 bg-orange-600 text-white rounded-2xl flex items-center justify-center text-3xl font-bold shadow-md">
            🚩
          </div>
          <div>
            <h2 class="text-xl font-bold text-gray-900">Shri Hanuman Chalisa</h2>
            <p class="text-xs font-semibold text-orange-600 uppercase tracking-wider">Devotional Lyrics & Audio</p>
          </div>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed mb-6 flex-grow">
          Read and listen to the divine verses of the Hanuman Chalisa. Features high-quality audio recitation, multiple languages, clean formatting, offline availability, and intuitive reading views for peaceful daily devotion.
        </p>
        <a 
          href="https://play.google.com/store/apps/details?id=com.shrihanumanchalisa.app" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="inline-flex items-center justify-center gap-2.5 bg-zinc-900 hover:bg-zinc-800 text-white px-5 py-3 rounded-xl font-bold text-sm transition-all group mt-auto w-full sm:w-max"
        >
          <svg class="w-5 h-5 text-white fill-current" viewBox="0 0 512 512">
            <path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58 33.3-60.7-60.7 118.7 27.4c15.9 3.7 21.8 14.1 21.8 22.2 0 8.1-5.9 18.5-21.8 22.2zM325.3 277.7L385.4 338 104.6 499l220.7-221.3z"/>
          </svg>
          Get on Google Play
        </a>
      </div>

      <!-- 3. Women Fitness Pro App -->
      <div class="bg-white border border-gray-150 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col p-6 sm:p-8">
        <div class="flex items-start gap-4 mb-4">
          <div class="w-16 h-16 bg-pink-500 text-white rounded-2xl flex items-center justify-center text-3xl font-bold shadow-md">
            🧘‍♀️
          </div>
          <div>
            <h2 class="text-xl font-bold text-gray-900">Women Fitness Pro</h2>
            <p class="text-xs font-semibold text-pink-500 uppercase tracking-wider">Health & Workout Planner</p>
          </div>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed mb-6 flex-grow">
          Reach your personal health goals with customized workout routines, diet planners, water reminders, and daily habit trackers designed specifically for women. Build a healthier lifestyle with no gym equipment required.
        </p>
        <a 
          href="https://play.google.com/store/apps/details?id=com.womenfitness.women_fitness_pro" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="inline-flex items-center justify-center gap-2.5 bg-zinc-900 hover:bg-zinc-800 text-white px-5 py-3 rounded-xl font-bold text-sm transition-all group mt-auto w-full sm:w-max"
        >
          <svg class="w-5 h-5 text-white fill-current" viewBox="0 0 512 512">
            <path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58 33.3-60.7-60.7 118.7 27.4c15.9 3.7 21.8 14.1 21.8 22.2 0 8.1-5.9 18.5-21.8 22.2zM325.3 277.7L385.4 338 104.6 499l220.7-221.3z"/>
          </svg>
          Get on Google Play
        </a>
      </div>

      <!-- 4. Hanuman Bhakti App -->
      <div class="bg-white border border-gray-150 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col p-6 sm:p-8">
        <div class="flex items-start gap-4 mb-4">
          <div class="w-16 h-16 bg-red-600 text-white rounded-2xl flex items-center justify-center text-3xl font-bold shadow-md">
            🔱
          </div>
          <div>
            <h2 class="text-xl font-bold text-gray-900">Hanuman Bhakti</h2>
            <p class="text-xs font-semibold text-red-600 uppercase tracking-wider">Devotional & Bhajan Hub</p>
          </div>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed mb-6 flex-grow">
          Your ultimate companion for Lord Hanuman devotion. Features an interactive collection of devotional bhajans, high-definition wallpapers, quotes, and spiritual stories to guide your daily devotional needs.
        </p>
        <a 
          href="https://play.google.com/store/apps/details?id=com.devotional.hanuman_bhakti.hanuman_bhakti" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="inline-flex items-center justify-center gap-2.5 bg-zinc-900 hover:bg-zinc-800 text-white px-5 py-3 rounded-xl font-bold text-sm transition-all group mt-auto w-full sm:w-max"
        >
          <svg class="w-5 h-5 text-white fill-current" viewBox="0 0 512 512">
            <path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58 33.3-60.7-60.7 118.7 27.4c15.9 3.7 21.8 14.1 21.8 22.2 0 8.1-5.9 18.5-21.8 22.2zM325.3 277.7L385.4 338 104.6 499l220.7-221.3z"/>
          </svg>
          Get on Google Play
        </a>
      </div>

    </div>

  </div>
</BaseLayout>
