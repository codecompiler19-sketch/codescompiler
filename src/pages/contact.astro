---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Contact CodesCompiler for support and inquiries.">
  <div class="max-w-xl mx-auto py-12 px-4 sm:px-6 lg:px-8 bg-white shadow-sm my-8 rounded-lg">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-6 text-center">Contact Us</h1>
    <p class="text-center text-gray-600 mb-8">We'd love to hear from you. Please fill out the form below or email us directly.</p>
    
    <form class="space-y-6" action="#" method="POST" onsubmit="event.preventDefault(); alert('This is a demo. Email would be sent here.');">
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
        <div class="mt-1">
          <input type="text" name="name" id="name" class="shadow-sm focus:ring-brand focus:border-brand block w-full sm:text-sm border-gray-300 rounded-md p-2 border" placeholder="Your Name" required>
        </div>
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
        <div class="mt-1">
          <input type="email" name="email" id="email" class="shadow-sm focus:ring-brand focus:border-brand block w-full sm:text-sm border-gray-300 rounded-md p-2 border" placeholder="you@example.com" required>
        </div>
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
        <div class="mt-1">
          <textarea id="message" name="message" rows="4" class="shadow-sm focus:ring-brand focus:border-brand block w-full sm:text-sm border-gray-300 rounded-md p-2 border" placeholder="How can we help?" required></textarea>
        </div>
      </div>
      <div>
        <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-brand hover:bg-brand-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand transition-colors">
          Send Message
        </button>
      </div>
    </form>
    
    <div class="mt-8 text-center text-sm text-gray-500">
      Or email us at <a href="mailto:support@codescompiler.com" class="text-brand hover:underline">support@codescompiler.com</a>
    </div>
  </div>
</BaseLayout>
