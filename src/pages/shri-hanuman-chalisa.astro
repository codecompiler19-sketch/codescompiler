---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Shri Hanuman Chalisa - Lyrics, Devotional Hymn & Meaning" 
  description="Read the complete Shri Hanuman Chalisa in Hindi (Devanagari) and English transliteration. Experience the powerful devotional hymn dedicated to Lord Hanuman."
>
  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8 my-8">
    
    <!-- Hero Banner Accent -->
    <div class="bg-gradient-to-r from-amber-500 via-orange-600 to-red-600 rounded-3xl p-8 sm:p-12 text-white text-center shadow-lg mb-10 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#fff_1px,transparent_1px)] bg-[size:16px_16px]"></div>
      <span class="text-4xl sm:text-5xl mb-4 block animate-bounce">🚩</span>
      <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight mb-3">Shri Hanuman Chalisa</h1>
      <p class="text-base sm:text-lg text-amber-100 max-w-2xl mx-auto">
        A sacred 40-verse hymn composed by Goswami Tulsidas in praise of Lord Hanuman, the epitome of devotion, strength, and wisdom.
      </p>
    </div>

    <!-- Main Content Card -->
    <div class="bg-white shadow-xl rounded-2xl border border-orange-50 overflow-hidden">
      
      <!-- Quick Info / Intro -->
      <div class="bg-orange-50/50 px-6 py-6 border-b border-orange-100 text-center sm:text-left">
        <h2 class="text-lg font-bold text-orange-800 flex items-center justify-center sm:justify-start gap-2 mb-2">
          <span>✨</span> About the Chalisa
        </h2>
        <p class="text-sm text-gray-600 leading-relaxed">
          The Hanuman Chalisa is traditionally recited to invoke Lord Hanuman's protection and blessings, and to remove obstacles and fears from one's life. Each verse (Chaupai) holds immense spiritual significance.
        </p>
      </div>

      <!-- Tabbed view or stacked side-by-side layout -->
      <div class="px-6 sm:px-12 py-10 space-y-12">
        
        <!-- DOHA 1 & 2 -->
        <div class="text-center bg-amber-50/40 rounded-xl p-6 border border-amber-100">
          <h3 class="text-xl font-bold text-orange-700 mb-4 tracking-wide">॥ दोहा (Doha) ॥</h3>
          
          <div class="space-y-6 text-gray-800">
            <div class="space-y-2">
              <p class="text-lg font-semibold text-gray-900 leading-relaxed">
                श्रीगुरु चरन सरोज रज निज मनु मुकुरु सुधारि ।<br/>
                बरनउँ रघुबर बिमल जसु जो दायकु फल चारि ॥
              </p>
              <p class="text-xs sm:text-sm text-zinc-500 italic">
                Shree Guru Charan Saroj Raj, Nij Man Mukut Sudhari |<br/>
                Barnau Raghuvar Bimal Jasu, Jo Dayaku Phal Chari ||
              </p>
            </div>

            <div class="w-16 h-[1px] bg-amber-200 mx-auto"></div>

            <div class="space-y-2">
              <p class="text-lg font-semibold text-gray-900 leading-relaxed">
                बुद्धिहीन तनु जानिके सुमिरौं पवन-कुमार ।<br/>
                बल बुधि बिद्या देहु मोहिं हरहु कलेस बिकार ॥
              </p>
              <p class="text-xs sm:text-sm text-zinc-500 italic">
                Buddhiheen Tanu Janike, Sumirau Pawan-Kumar |<br/>
                Bal Budhi Vidya Dehu Mohi, Harahu Kalesh Bikaar ||
              </p>
            </div>
          </div>
        </div>

        <!-- CHAUPAI -->
        <div class="space-y-8">
          <h3 class="text-xl font-bold text-orange-700 text-center tracking-wide border-b border-orange-100 pb-3">
            ॥ चौपाई (Chaupai) ॥
          </h3>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            
            <!-- Verses 1 - 20 -->
            <div class="space-y-6">
              <!-- 1 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">1</p>
                <p class="font-bold text-gray-900">जय हनुमान ज्ञान गुन सागर । जय कपीस तिहुँ लोक उजागर ॥</p>
                <p class="text-xs text-gray-500 italic">Jai Hanuman Gyan Gun Sagar | Jai Kapis Tihun Lok Ujagar ||</p>
              </div>
              <!-- 2 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">2</p>
                <p class="font-bold text-gray-900">रामदूत अतुलित बल धामा । अंजनि-पुत्र पवनसुत नामा ॥</p>
                <p class="text-xs text-gray-500 italic">Ramdoot Atulit Bal Dhama | Anjani-Putra Pawansut Nama ||</p>
              </div>
              <!-- 3 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">3</p>
                <p class="font-bold text-gray-900">महाबीर बिक्रम बजरंगी । कुमति निवार सुमति के संगी ॥</p>
                <p class="text-xs text-gray-500 italic">Mahabeer Bikram Bajrangi | Kumati Nivar Sumati Ke Sangi ||</p>
              </div>
              <!-- 4 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">4</p>
                <p class="font-bold text-gray-900">कंचन बरन बिराज सुबेसा । कानन कुंडल कुंचित केसा ॥</p>
                <p class="text-xs text-gray-500 italic">Kanchan Baran Biraj Subesa | Kanan Kundal Kunchit Kesa ||</p>
              </div>
              <!-- 5 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">5</p>
                <p class="font-bold text-gray-900">हाथ बज्र औ ध्वजा बिराजै । काँधे मूँज जनेऊ साजै ॥</p>
                <p class="text-xs text-gray-500 italic">Hath Bajra Au Dhwaja Biraje | Kandhe Moonj Janeu Saje ||</p>
              </div>
              <!-- 6 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">6</p>
                <p class="font-bold text-gray-900">संकर सुवन केसरीनंदन । तेज प्रताप महा जग बंदन ॥</p>
                <p class="text-xs text-gray-500 italic">Sankar Suvan Kesreenandan | Tej Pratap Maha Jag Bandan ||</p>
              </div>
              <!-- 7 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">7</p>
                <p class="font-bold text-gray-900">बिद्यावान गुनी अति चातुर । राम काज करिबे को आतुर ॥</p>
                <p class="text-xs text-gray-500 italic">Vidyawan Guni Ati Chatur | Ram Kaj Karibe Ko Aatur ||</p>
              </div>
              <!-- 8 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">8</p>
                <p class="font-bold text-gray-900">प्रभु चरित्र सुनिबे को रसिया । राम लखन सीता मन बसिया ॥</p>
                <p class="text-xs text-gray-500 italic">Prabhu Charitra Sunibe Ko Rasiya | Ram Lakhan Sita Man Basiya ||</p>
              </div>
              <!-- 9 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">9</p>
                <p class="font-bold text-gray-900">सूक्ष्म रूप धरि सियहिं दिखावा । बिकट रूप धरि लंक जरावा ॥</p>
                <p class="text-xs text-gray-500 italic">Sukshma Roop Dhari Siyahin Dikhawa | Bikat Roop Dhari Lank Jarawa ||</p>
              </div>
              <!-- 10 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">10</p>
                <p class="font-bold text-gray-900">भीम रूप धरि असुर सँहारे । रामचंद्र के काज सँवारे ॥</p>
                <p class="text-xs text-gray-500 italic">Bheem Roop Dhari Asur Sanhare | Ramchandra Ke Kaj Sanware ||</p>
              </div>
              <!-- 11 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">11</p>
                <p class="font-bold text-gray-900">लाय सजीवन लखन जियाए । श्रीरघुबीर हरषि उर लाए ॥</p>
                <p class="text-xs text-gray-500 italic">Lay Sajeevan Lakhan Jiyaye | Shree Raghuveer Harashi Ur Laye ||</p>
              </div>
              <!-- 12 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">12</p>
                <p class="font-bold text-gray-900">रघुपति कीन्ही बहुत बड़ाई । तुम मम प्रिय भरतहि सम भाई ॥</p>
                <p class="text-xs text-gray-500 italic">Raghupati Keenhi Bahut Badai | Tum Mama Priya Bharatahi Sam Bhai ||</p>
              </div>
              <!-- 13 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">13</p>
                <p class="font-bold text-gray-900">सहस बदन तुम्हरो जस गावैं । अस कहि श्रीपति कंठ लगावैं ॥</p>
                <p class="text-xs text-gray-500 italic">Sahas Badan Tumharo Jas Gaave | Asa Kahi Shreepati Kanth Lagave ||</p>
              </div>
              <!-- 14 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">14</p>
                <p class="font-bold text-gray-900">सनकादिक ब्रह्मादि मुनीसा । नारद सारद सहित अहीसा ॥</p>
                <p class="text-xs text-gray-500 italic">Sankadik Brahamadi Muneesa | Narad Sarad Sahit Aheesa ||</p>
              </div>
              <!-- 15 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">15</p>
                <p class="font-bold text-gray-900">जम कुबेर दिगपाल जहाँ ते । कबि कोबिद कहि सकैं कहाँ ते ॥</p>
                <p class="text-xs text-gray-500 italic">Yam Kuber Digpal Jahan Te | Kabi Kobid Kahi Sake Kahan Te ||</p>
              </div>
              <!-- 16 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">16</p>
                <p class="font-bold text-gray-900">तुम उपकार सुग्रीवहिं कीन्हा । राम मिलाय राज पद दीन्हा ॥</p>
                <p class="text-xs text-gray-500 italic">Tum Upkar Sugreevahin Keenha | Ram Milai Rajpad Deenha ||</p>
              </div>
              <!-- 17 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">17</p>
                <p class="font-bold text-gray-900">तुम्हरो मंत्र बिभीषन माना । लंकेस्वर भए सब जग जाना ॥</p>
                <p class="text-xs text-gray-500 italic">Tumharo Mantra Vibheeshan Mana | Lankeshwar Bhaye Sab Jag Jana ||</p>
              </div>
              <!-- 18 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">18</p>
                <p class="font-bold text-gray-900">जुग सहस्र जोजन पर भानू । लील्यो ताहि मधुर फल जानू ॥</p>
                <p class="text-xs text-gray-500 italic">Yug Sahasra Yojan Par Bhanu | Leelyo Tahi Madhur Phal Janu ||</p>
              </div>
              <!-- 19 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">19</p>
                <p class="font-bold text-gray-900">प्रभु मुद्रिका मेलि मुख माहीं । जलधि लाँघि गये अचरज नाहीं ॥</p>
                <p class="text-xs text-gray-500 italic">Prabhu Mudrika Meli Mukh Mahee | Jaladhi Langhi Gaye Acharaj Nahee ||</p>
              </div>
              <!-- 20 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">20</p>
                <p class="font-bold text-gray-900">दुर्गम काज जगत के जेते । सुगम अनुग्रह तुम्हरे तेते ॥</p>
                <p class="text-xs text-gray-500 italic">Durgam Kaj Jagat Ke Jete | Sugam Anugrah Tumhre Tete ||</p>
              </div>
            </div>

            <!-- Verses 21 - 40 -->
            <div class="space-y-6">
              <!-- 21 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">21</p>
                <p class="font-bold text-gray-900">राम दुआरे तुम रखवारे । होत न आग्या बिनु पैसारे ॥</p>
                <p class="text-xs text-gray-500 italic">Ram Duare Tum Rakhware | Hot Na Aagya Binu Paisare ||</p>
              </div>
              <!-- 22 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">22</p>
                <p class="font-bold text-gray-900">सब सुख लहै तुम्हारी सरना । तुम रक्षक काहू को डर ना ॥</p>
                <p class="text-xs text-gray-500 italic">Sab Sukh Lahe Tumhari Sarna | Tum Rakshak Kahu Ko Dar Na ||</p>
              </div>
              <!-- 23 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">23</p>
                <p class="font-bold text-gray-900">आपन तेज सम्हारो आपै । तीनों लोक हाँक तें काँपै ॥</p>
                <p class="text-xs text-gray-500 italic">Aapan Tej Samharo Aape | Teenon Lok Hank Te Kampe ||</p>
              </div>
              <!-- 24 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">24</p>
                <p class="font-bold text-gray-900">भूत पिसच निकट नहिं आवै । महाबीर जब नाम सुनावै ॥</p>
                <p class="text-xs text-gray-500 italic">Bhoot Pisach Nikat Nahi Aave | Mahabeer Jab Naam Sunave ||</p>
              </div>
              <!-- 25 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">25</p>
                <p class="font-bold text-gray-900">नासै रोग हरै सब पीरा । जपत निरंतर हनुमत बीरा ॥</p>
                <p class="text-xs text-gray-500 italic">Nase Rog Hare Sab Peera | Japat Nirantar Hanumat Beera ||</p>
              </div>
              <!-- 26 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">26</p>
                <p class="font-bold text-gray-900">संकट तें हनुमान छुड़ावै । मन क्रम बचन ध्यान जो लावै ॥</p>
                <p class="text-xs text-gray-500 italic">Sankat Te Hanuman Chhudave | Man Kram Bachan Dhyan Jo Lave ||</p>
              </div>
              <!-- 27 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">27</p>
                <p class="font-bold text-gray-900">सब पर राम तपस्वी राजा । तिन के काज सकल तुम साजा ॥</p>
                <p class="text-xs text-gray-500 italic">Sab Par Ram Tapaswee Raja | Tin Ke Kaj Sakal Tum Saja ||</p>
              </div>
              <!-- 28 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">28</p>
                <p class="font-bold text-gray-900">और मनोरथ जो कोई लावै । सोइ अमित जीवन फल पावै ॥</p>
                <p class="text-xs text-gray-500 italic">Aur Manorath Jo Koi Lave | Soi Amit Jeevan Phal Pave ||</p>
              </div>
              <!-- 29 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">29</p>
                <p class="font-bold text-gray-900">चारों जुग परताप तुम्हारा । है परसिद्ध जगत उजियारा ॥</p>
                <p class="text-xs text-gray-500 italic">Charon Yug Partap Tumhara | Hai Parsiddh Jagat Ujiyara ||</p>
              </div>
              <!-- 30 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">30</p>
                <p class="font-bold text-gray-900">साधु संत के तुम रखवारे । असुर निकंदन राम दुलारे ॥</p>
                <p class="text-xs text-gray-500 italic">Sadhu Sant Ke Tum Rakhware | Asur Nikandan Ram Dulare ||</p>
              </div>
              <!-- 31 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">31</p>
                <p class="font-bold text-gray-900">अष्टसिद्धि नौ निधि के दाता । अस बर दीन्ह जानकी माता ॥</p>
                <p class="text-xs text-gray-500 italic">Asht Siddhi Nau Nidhi Ke Data | Asa Bar Deenh Janaki Mata ||</p>
              </div>
              <!-- 32 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">32</p>
                <p class="font-bold text-gray-900">राम रसायन तुम्हरे पासा । सदा रहो रघुपति के दासा ॥</p>
                <p class="text-xs text-gray-500 italic">Ram Rasayan Tumhare Pasa | Sada Raho Raghupati Ke Dasa ||</p>
              </div>
              <!-- 33 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">33</p>
                <p class="font-bold text-gray-900">तुम्हरे भजन राम को पावै । जनम जनम के दुख बिसरावै ॥</p>
                <p class="text-xs text-gray-500 italic">Tumhare Bhajan Ram Ko Paave | Janam Janam Ke Dukh Bisrave ||</p>
              </div>
              <!-- 34 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">34</p>
                <p class="font-bold text-gray-900">अंत काल रघुबर पुर जाई । जहाँ जनम हरिभक्त कहाई ॥</p>
                <p class="text-xs text-gray-500 italic">Antakal Raghuvar Pur Jai | Jahan Janam Haribhakt Kahai ||</p>
              </div>
              <!-- 35 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">35</p>
                <p class="font-bold text-gray-900">और देवता चित्त न धरई । हनुमत सेइ सर्ब सुख करई ॥</p>
                <p class="text-xs text-gray-500 italic">Aur Devta Chitta Na Dharai | Hanumat Sei Sab Sukh Karai ||</p>
              </div>
              <!-- 36 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">36</p>
                <p class="font-bold text-gray-900">संकट कटै मिटै सब पीरा । जो सुमिरै हनुमत बलबीरा ॥</p>
                <p class="text-xs text-gray-500 italic">Sankat Kate Mite Sab Peera | Jo Sumire Hanumat Balbeera ||</p>
              </div>
              <!-- 37 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">37</p>
                <p class="font-bold text-gray-900">जय जय जय हनुमान गोसाईं । कृपा करहु गुरुदेव की नाईं ॥</p>
                <p class="text-xs text-gray-500 italic">Jai Jai Jai Hanuman Gosai | Kripa Karahu Gurudev Ki Nai ||</p>
              </div>
              <!-- 38 -->
              <div class="border-l-2 border-orange-500 pl-4 space-y-1">
                <p class="text-sm font-semibold text-gray-500">38</p>
                <p class="font-bold text-gray-900">जो सत बार पाठ कर कोई । छूटहि बंदि महा सुख होई ॥</p>
                <p class="text-xs text-gray-500 italic">Jo Sat Bar Path Kar Koi | Chhootahi Bandi Maha Sukh Hoi ||</p>
              </div>
