{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "Tutorial",
      "pageBundle": false,
      "filePrefix": null,
      "fileType": "mdx",
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string",
          "required": true,
          "description": "The title shown on the page and in the browser tab"
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string",
          "required": true,
          "description": "One-sentence SEO description for this page"
        },
        {
          "title": "Category",
          "name": "category",
          "type": "choice",
          "required": true,
          "choices": ["html", "css", "javascript"],
          "description": "Which tutorial section this belongs to"
        },
        {
          "title": "Order",
          "name": "order",
          "type": "number",
          "required": true,
          "description": "Sidebar sort position (1 = first chapter)"
        },
        {
          "title": "Date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true
        }
      ]
    }
  ],
  "frontMatter.content.publicFolder": "public",
  "frontMatter.content.pageFolders": [
    {
      "title": "Tutorials",
      "path": "[[workspace]]/src/content/tutorials",
      "contentTypes": ["Tutorial"],
      "defaultLocale": "en"
    }
  ],
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.autoUpdateDate": true,
  "frontMatter.dashboard.openOnStart": true,
  "frontMatter.global.activeMode": "default",
  "frontMatter.content.defaultFileType": "mdx",
  "frontMatter.panel.actions.disabled": []
}
